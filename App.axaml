<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MCto3D.App"
             RequestedThemeVariant="Dark">
             
    <Application.Resources>
        <ResourceDictionary>
            <!-- Ender Theme Colors -->
            <SolidColorBrush x:Key="EnderBackgroundBase">#05050A</SolidColorBrush>
            <SolidColorBrush x:Key="EnderSurface">#0B0B13</SolidColorBrush>
            <SolidColorBrush x:Key="EnderSurfaceHover">#13101E</SolidColorBrush>
            <SolidColorBrush x:Key="EnderPrimary">#7C3AED</SolidColorBrush>
            <SolidColorBrush x:Key="EnderPrimaryHover">#6D28D9</SolidColorBrush>
            <SolidColorBrush x:Key="EnderSecondary">#10B981</SolidColorBrush>
            <SolidColorBrush x:Key="EnderTextPrimary">#F8FAFC</SolidColorBrush>
            <SolidColorBrush x:Key="EnderTextSecondary">#94A3B8</SolidColorBrush>
            <SolidColorBrush x:Key="EnderBorder">#1E1B2E</SolidColorBrush>
            <SolidColorBrush x:Key="EnderDisabled">#2b0416</SolidColorBrush>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
        
        <!-- Ender Theme Global Styles -->
        
        <!-- Primary Button -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="{DynamicResource EnderPrimary}"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderTextPrimary}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="SineEaseInOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource EnderPrimaryHover}"/>
        </Style>

        <!-- Secondary Outline Button -->
        <Style Selector="Button.Outline">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource EnderPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Outline:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource EnderSurfaceHover}"/>
        </Style>

        <!-- Ghost / Sidebar Button -->
        <Style Selector="Button.Ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderTextSecondary}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource EnderSurfaceHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderPrimary}"/>
        </Style>
        <Style Selector="Button.Ghost:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource EnderSurfaceHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderPrimary}"/>
            <Setter Property="Opacity" Value="1.0"/>
        </Style>

        <!-- Card Border -->
        <Style Selector="Border.Card">
            <Setter Property="Background" Value="{DynamicResource EnderSurface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource EnderBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
	        <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="ZIndex" Value="0" />
        </Style>

        <!-- Typography -->
        <Style Selector="TextBlock.H1">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderTextPrimary}"/>
        </Style>
        <Style Selector="TextBlock.H2">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderTextPrimary}"/>
        </Style>
        <Style Selector="TextBlock.H3">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderTextPrimary}"/>
        </Style>
        <Style Selector="TextBlock.Subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderTextSecondary}"/>
        </Style>
        <Style Selector="TextBlock.SettingsLabel">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderTextSecondary}"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <!-- Inputs -->
        <Style Selector="TextBox.Modern">
            <Setter Property="Background" Value="{DynamicResource EnderSurfaceHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource EnderBorder}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="ComboBox.Modern">
            <Setter Property="Background" Value="{DynamicResource EnderSurfaceHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderTextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource EnderBorder}"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <!-- Extra Buttons -->
        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="SineEaseInOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#DC2626"/>
        </Style>

        <Style Selector="Button.Hyperlink">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource EnderPrimary}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline"/>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.Hyperlink:pointerover /template/ TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource EnderPrimaryHover}"/>
        </Style>
    </Application.Styles>
</Application>