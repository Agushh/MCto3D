<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="using:System">
    
    <!-- App General -->
    <sys:String x:Key="AppTitle">MCto3D</sys:String>
    
    <!-- Sidebar -->
    <sys:String x:Key="SidebarMenu">MENÚ</sys:String>
    <sys:String x:Key="SidebarHome">Inicio</sys:String>
    <sys:String x:Key="SidebarConverter">Convertidor</sys:String>
    <sys:String x:Key="SidebarMyFiles">Mis Archivos</sys:String>
    <sys:String x:Key="SidebarVanillaStructures">Estructuras Vanilla</sys:String>
    <sys:String x:Key="SidebarWalkthrough">Tutorial</sys:String>
    <sys:String x:Key="SidebarFaq">FAQ</sys:String>
    <sys:String x:Key="SidebarSettings">Ajustes</sys:String>
    <sys:String x:Key="SidebarDevTools">Dev Tools</sys:String>

    <!-- Home Menu -->
    <sys:String x:Key="HomeTitle">Minecraft to 3D Model</sys:String>
    <sys:String x:Key="HomeSubtitle">¡Dale vida a tus construcciones!</sys:String>
    <sys:String x:Key="HomeConvertBtn">¡CONVERTIR!</sys:String>
    <sys:String x:Key="HomeLearnMore">ver más...</sys:String>
    <sys:String x:Key="HomeDescription">Una herramienta poderosa para convertir estructuras de Minecraft en modelos 3D de alta calidad para renderizado, impresión y más.</sys:String>

    <!-- Welcome Screen -->
    <sys:String x:Key="WelcomeTitle">¡Bienvenido a MCto3D!</sys:String>
    <sys:String x:Key="WelcomeDesc">Al ser un programa externo a Mojang, no podemos incluir ciertas configuraciones y necesitamos procesar un archivo de versión de Minecraft, por lo que es vital que tengas Minecraft instalado en tu computadora.</sys:String>
    <sys:String x:Key="WelcomeContinueBtn">Continuar</sys:String>
    <sys:String x:Key="WelcomeContinueTooltip">Intentará buscar Minecraft en la ruta por defecto</sys:String>
    <sys:String x:Key="WelcomeCustomFolderBtn">¿Tienes instalado Minecraft en otra carpeta? Haz click aquí y búscala.</sys:String>

    <!-- Converter (Dashboard) -->
    <sys:String x:Key="ConverterTitle">Convertidor</sys:String>
    <sys:String x:Key="ConverterNoFileTitle">Arrastra o busca tu estructura</sys:String>
    <sys:String x:Key="ConverterNoFileDesc">Soporta archivos .nbt exportados de Structure Blocks</sys:String>
    <sys:String x:Key="ConverterSelectFileBtn">Seleccionar Archivo</sys:String>
    <sys:String x:Key="ConverterAdmittedTypes">Tipos admitidos: .nbt, .schematic</sys:String>
    <sys:String x:Key="ConverterActiveFile">Archivo activo:</sys:String>
    <sys:String x:Key="ConverterMeshSettings">Ajustes de Malla</sys:String>
    <sys:String x:Key="ConverterBlockScale">Escala de Bloque (bs):</sys:String>
    <sys:String x:Key="ConverterGeomMode">Modo de Geometría:</sys:String>
    <sys:String x:Key="ConverterGeomSolid">Bloques sólidos</sys:String>
    <sys:String x:Key="ConverterGeomFull">Geometrías completas</sys:String>
    <sys:String x:Key="ConverterOutFormat">Formato de salida:</sys:String>
    <sys:String x:Key="ConverterColorMgmt">Gestión de color:</sys:String>
    <sys:String x:Key="ConverterMono">Monocolor</sys:String>
    <sys:String x:Key="ConverterMulti">Multicolor (NBT)</sys:String>
    <sys:String x:Key="Converter3DModel">Modelo 3D:</sys:String>
    <sys:String x:Key="ConverterForceColor">Forzar color</sys:String>
    <sys:String x:Key="ConverterScene">Escenario:</sys:String>
    <sys:String x:Key="ConverterAddFloor">Añadir suelo</sys:String>
    <sys:String x:Key="ConverterExportLocal">Exportar Local</sys:String>
    <sys:String x:Key="ConverterSaveApp">⭐ Guardar en App</sys:String>
    <sys:String x:Key="ConverterFillHoles">Llenar huecos internos</sys:String>
    <sys:String x:Key="ConverterFillColor">Color de relleno</sys:String>
    <sys:String x:Key="ConverterUseCustom">Usar personalizado</sys:String>
    <sys:String x:Key="Converter3MfOptions">Opciones de 3MF</sys:String>
    <sys:String x:Key="ConverterAlgorithm">Algoritmo</sys:String>
    <sys:String x:Key="ConverterPalette">Paleta</sys:String>
    <sys:String x:Key="ConverterPaletteCustom">Personalizada...</sys:String>
    <sys:String x:Key="ConverterCustomPalette">Paleta Personalizada</sys:String>
    <sys:String x:Key="ConverterPredefinedPalette">Paleta Predefinida</sys:String>
    <sys:String x:Key="ConverterKMeansAvg">K-Means (Color Promedio)</sys:String>
    <sys:String x:Key="ConverterKMedoids">K-Medoids (Color Real)</sys:String>
    <sys:String x:Key="ConverterRawColors">Colores Crudos (Sin procesar)</sys:String>
    <sys:String x:Key="ConverterOpenIn">Abrir en</sys:String>
    <sys:String x:Key="ConverterOptionalName">Nombre (Opcional)</sys:String>
    <sys:String x:Key="ConverterAddColor">+ Agregar Color</sys:String>
    <sys:String x:Key="ConverterInfo">Información</sys:String>
    <sys:String x:Key="ConverterColorCount">Cantidad de colores:</sys:String>
    <sys:String x:Key="ConverterAmountK">Cantidad (K)</sys:String>
    <sys:String x:Key="ConverterPaletteSize">Tamaño de Paleta</sys:String>

    <!-- Global -->
    <sys:String x:Key="GlobalYes">Sí</sys:String>
    <sys:String x:Key="GlobalNo">No</sys:String>
    <sys:String x:Key="GlobalSave">Guardar</sys:String>
    <sys:String x:Key="GlobalSaveChanges">Guardar Cambios</sys:String>
    <sys:String x:Key="GlobalUpdate">Actualizar</sys:String>
    <sys:String x:Key="GlobalDelete">Borrar</sys:String>
    <sys:String x:Key="GlobalClose">Cerrar</sys:String>

    <sys:String x:Key="ConverterFutureAds">Future Ads</sys:String>
    <sys:String x:Key="ConverterInteractiveViewer">Visor Interactivo</sys:String>
    <sys:String x:Key="ConverterLiveRender">Live Render</sys:String>
    <sys:String x:Key="ConverterGeneratingMesh">Generando Malla 3D...</sys:String>
    <sys:String x:Key="ConverterWaitMsg">Por favor espera, esto puede tardar unos segundos en estructuras grandes.</sys:String>
    <sys:String x:Key="ConverterSavePopupTitle">Guardar en Mis Archivos</sys:String>
    <sys:String x:Key="ConverterSavePopupDesc">Dale un nombre y elige el ángulo de miniatura para guardarlo en tu galería.</sys:String>
    <sys:String x:Key="ConverterSavePopupPlaceholder">Nombre del proyecto...</sys:String>
    <sys:String x:Key="ConverterCancelBtn">Cancelar</sys:String>
    <sys:String x:Key="ConverterSaveBtn">Guardar</sys:String>

    <!-- Settings -->
    <sys:String x:Key="SettingsTitle">Ajustes</sys:String>
    <sys:String x:Key="SettingsGeneral">General</sys:String>
    <sys:String x:Key="SettingsLanguage">Idioma</sys:String>
    <sys:String x:Key="SettingsLanguageDesc">Selecciona el idioma de la aplicación.</sys:String>
    <sys:String x:Key="SettingsLocalFiles">Archivos Locales</sys:String>
    <sys:String x:Key="SettingsMCVersion">Versión de Minecraft</sys:String>
    <sys:String x:Key="SettingsMCVersionDesc">Versión actualmente extraída de la cual se leen los modelos.</sys:String>
    <sys:String x:Key="SettingsLocalPath">Ruta de archivos locales</sys:String>
    <sys:String x:Key="SettingsLocalPathDesc">Carpeta donde se guardan los modelos extraídos, caché y proyectos de usuario.</sys:String>
    <sys:String x:Key="SettingsChangePathBtn">Cambiar Ruta</sys:String>
    <sys:String x:Key="SettingsOpenFolder">Abrir Carpeta Local</sys:String>
    <sys:String x:Key="SettingsRestoreFolder">Restaurar por defecto</sys:String>
    <sys:String x:Key="SettingsReloadActions">Acciones de Recarga</sys:String>
    <sys:String x:Key="SettingsReloadBaseFiles">Recargar archivos base del juego</sys:String>
    <sys:String x:Key="SettingsReloadBaseFilesDesc">Abre el selector para extraer los recursos de Minecraft nuevamente.</sys:String>
    <sys:String x:Key="SettingsReloadDesc">Cargar datos de bloques e idiomas</sys:String>
    <sys:String x:Key="SettingsReloadBtn">Recargar</sys:String>
    <sys:String x:Key="SettingsConverter3MfOptions">Opciones 3MF</sys:String>
    <sys:String x:Key="SettingsConverter3MfAssembly">Agrupar como ensamblaje</sys:String>
    <sys:String x:Key="SettingsConverter3MfSeparate">Mantener piezas separadas</sys:String>
    <sys:String x:Key="SettingsConverterPaletteManagement">Gestión de Paletas</sys:String>
    <sys:String x:Key="SettingsConverterManagePalettes">Gestionar Paletas</sys:String>
    <sys:String x:Key="SettingsConverterDeleteAllPalettes">Borrar todas las paletas</sys:String>
    <sys:String x:Key="SettingsRendererVisuals">Ajustes Visuales</sys:String>
    <sys:String x:Key="SettingsRendererFloor">Suelo</sys:String>
    <sys:String x:Key="SettingsRendererMeshColor">Color de Malla</sys:String>
    <sys:String x:Key="SettingsRendererComingSoon">Los ajustes de renderizado llegarán pronto...</sys:String>
    <sys:String x:Key="SettingsAbout">Acerca de</sys:String>
    <sys:String x:Key="SettingsMovingFiles">Moviendo Archivos...</sys:String>
    <sys:String x:Key="SettingsCalculatingFiles">Calculando archivos...</sys:String>
    <sys:String x:Key="SettingsMovingProgress">Moviendo archivos... ({0} / {1})</sys:String>
    <sys:String x:Key="SettingsCleaningOldFiles">Limpiando archivos antiguos...</sys:String>
    <sys:String x:Key="SettingsMovingError">Error: {0}</sys:String>

    <!-- My Files -->
    <sys:String x:Key="MyFilesTitle">Mis Archivos</sys:String>
    <sys:String x:Key="MyFilesSearch">Buscar proyectos...</sys:String>
    <sys:String x:Key="MyFilesSortRecent">Más Recientes</sys:String>
    <sys:String x:Key="MyFilesSortName">Nombre (A-Z)</sys:String>
    <sys:String x:Key="MyFilesViewGrid">Vista de Cuadrícula</sys:String>
    <sys:String x:Key="MyFilesViewList">Vista de Lista</sys:String>
    <sys:String x:Key="MyFilesBack">Volver</sys:String>
    <sys:String x:Key="MyFilesEmpty">No tienes archivos guardados aún.</sys:String>
    <sys:String x:Key="MyFilesProjectDetails">Detalles del Proyecto</sys:String>
    <sys:String x:Key="MyFilesSave">Guardar</sys:String>
    <sys:String x:Key="MyFilesCancel">Cancelar</sys:String>
    <sys:String x:Key="MyFilesDate">Fecha:</sys:String>
    <sys:String x:Key="MyFilesGeometry">Geometría:</sys:String>
    <sys:String x:Key="MyFilesFormat">Formato:</sys:String>
    <sys:String x:Key="MyFilesScale">Escala (bs):</sys:String>
    <sys:String x:Key="MyFilesDelete">🗑 Borrar</sys:String>
    <sys:String x:Key="MyFilesExportLocal">Exportar Local</sys:String>

    <!-- Vanilla Structures -->
    <sys:String x:Key="VanillaTitle">Estructuras Vanilla</sys:String>
    <sys:String x:Key="VanillaDesc">Explora y convierte estructuras internas del juego</sys:String>
    <sys:String x:Key="VanillaSearch">Buscar...</sys:String>
    <sys:String x:Key="VanillaBack">Volver</sys:String>
    <sys:String x:Key="VanillaEmpty">No hay estructuras en esta carpeta.</sys:String>
    <sys:String x:Key="VanillaOpen">⚙ Abrir</sys:String>
    <sys:String x:Key="VanillaOpenTooltip">Carga esta estructura en el Conversor 3D</sys:String>
    <!-- Status and Progress Messages -->
    <sys:String x:Key="StatusWaitingFile">Esperando archivo NBT o 3MF...</sys:String>
    <sys:String x:Key="StatusFileLoaded">Archivo cargado:</sys:String>
    <sys:String x:Key="StatusErrorOpenFile">Error al abrir el archivo:</sys:String>
    <sys:String x:Key="StatusProcessingGeom">Procesando geometría para exportar...</sys:String>
    <sys:String x:Key="StatusExportSuccess">¡Exportado con éxito!</sys:String>
    <sys:String x:Key="StatusExportCancel">Exportación cancelada.</sys:String>
    <sys:String x:Key="StatusExportError">Error al cargar el archivo.</sys:String>
    <sys:String x:Key="ProgressInitColors">Iniciando procesamiento de colores para .3mf ...</sys:String>
    <sys:String x:Key="ProgressErrorTexture">Error: No se encontró la carpeta de texturas.</sys:String>
    <sys:String x:Key="ProgressErrorNoPng">Error: No se encontraron texturas .png procesables.</sys:String>
    <sys:String x:Key="ProgressSavingColors">Guardando archivo de colores...</sys:String>
    <sys:String x:Key="StatusSentToSlicer">¡Enviado al Slicer!</sys:String>
</ResourceDictionary>
