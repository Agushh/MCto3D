<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:MCto3D.ViewModels"
			 xmlns:controls="using:MCto3D.Controls"
			 x:Class="MCto3D.Views.HomeView"
			 x:DataType="vm:HomeViewModel">

	<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
		<StackPanel Spacing="12" Margin="32,16" HorizontalAlignment="Stretch">
			
			<!-- HEADER SECTION -->
			<StackPanel Spacing="4" HorizontalAlignment="Center">
				<TextBlock Text="{DynamicResource HomeTitle}" FontSize="42" FontWeight="Black" Foreground="{DynamicResource EnderTextPrimary}" HorizontalAlignment="Center" LetterSpacing="2"/>
				<TextBlock Text="{DynamicResource HomeSubtitle}" FontSize="20" Foreground="{DynamicResource EnderPrimary}" HorizontalAlignment="Center" FontStyle="Italic"/>
			</StackPanel>

			<!-- RENDER SECTION -->
			<Grid HorizontalAlignment="Center" Margin="0">
				<!-- Central Render Preview -->
				<Border Classes="Card" Width="800" Height="400" HorizontalAlignment="Center" ClipToBounds="True">
					<!-- Dummy overlay to simulate the sketch rectangle "Preview Renderer" text if no mesh is loaded, but actually we show the real renderer -->
					<Panel>
						<controls:MinecraftRenderControl Triangles="{Binding MeshTriangles}" ColoredMeshes="{Binding ColoredMeshes}" AutoRotate="True"/>
					</Panel>
				</Border>
			</Grid>

			<!-- START BUTTON -->
			<Button Content="{DynamicResource HomeConvertBtn}" Classes="Primary" Command="{Binding StartConverterCommand}" FontSize="24" Padding="64,16" HorizontalAlignment="Center" Cursor="Hand" Margin="0,16"/>

			<!-- SCROLL INDICATOR -->
			<StackPanel HorizontalAlignment="Center" Margin="0,8,0,16" Opacity="0.7">
				<TextBlock Text="{DynamicResource HomeLearnMore}" Foreground="{DynamicResource EnderTextSecondary}" FontSize="16" HorizontalAlignment="Center" FontStyle="Italic"/>
				<TextBlock Text="v" Foreground="{DynamicResource EnderTextSecondary}" FontSize="20" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,-4,0,0"/>
			</StackPanel>

			<Border Height="1" Background="{DynamicResource EnderBorder}" Margin="0,8"/>

			<!-- CAROUSEL SECTION -->
			<StackPanel Spacing="16">
				<!-- Interactive Carousel -->
				<Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Center" Margin="0,0,0,16">
					<!-- Prev Button -->
					<Button Grid.Column="0" Command="{Binding PrevCarouselImageCommand}" Classes="Ghost" Width="40" Height="40" CornerRadius="20" Padding="0" VerticalAlignment="Center" Margin="0,0,16,0" Cursor="Hand">
						<TextBlock Text="&lt;" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
					</Button>

					<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
						<Border Classes="Card" Width="200" Height="150" Opacity="0.6" ClipToBounds="True">
							<Image Source="{Binding PrevImage}" Stretch="UniformToFill"/>
						</Border>
						<Border Classes="Card" Width="400" Height="250" BorderBrush="{DynamicResource EnderPrimary}" BorderThickness="2" ClipToBounds="True">
							<Image Source="{Binding CurrentImage}" Stretch="UniformToFill"/>
						</Border>
						<Border Classes="Card" Width="200" Height="150" Opacity="0.6" ClipToBounds="True">
							<Image Source="{Binding NextImage}" Stretch="UniformToFill"/>
						</Border>
					</StackPanel>

					<!-- Next Button -->
					<Button Grid.Column="2" Command="{Binding NextCarouselImageCommand}" Classes="Ghost" Width="40" Height="40" CornerRadius="20" Padding="0" VerticalAlignment="Center" Margin="16,0,0,0" Cursor="Hand">
						<TextBlock Text="&gt;" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
					</Button>
				</Grid>
				
				<!-- Pagination dots -->
				<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
					<Ellipse Width="10" Height="10" Fill="{DynamicResource EnderPrimary}" IsVisible="{Binding IsDot0Active}"/>
					<Ellipse Width="8" Height="8" Stroke="{DynamicResource EnderTextSecondary}" StrokeThickness="2" IsVisible="{Binding !IsDot0Active}"/>

					<Ellipse Width="10" Height="10" Fill="{DynamicResource EnderPrimary}" IsVisible="{Binding IsDot1Active}"/>
					<Ellipse Width="8" Height="8" Stroke="{DynamicResource EnderTextSecondary}" StrokeThickness="2" IsVisible="{Binding !IsDot1Active}"/>

					<Ellipse Width="10" Height="10" Fill="{DynamicResource EnderPrimary}" IsVisible="{Binding IsDot2Active}"/>
					<Ellipse Width="8" Height="8" Stroke="{DynamicResource EnderTextSecondary}" StrokeThickness="2" IsVisible="{Binding !IsDot2Active}"/>
				</StackPanel>
			</StackPanel>

			<!-- ABOUT TEXT -->
			<StackPanel Spacing="8" MaxWidth="600" HorizontalAlignment="Left" Margin="64,32,0,0">
				<TextBlock Text="{DynamicResource AppTitle}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource EnderTextPrimary}"/>
				<TextBlock Text="{DynamicResource HomeDescription}" Foreground="{DynamicResource EnderTextSecondary}" FontSize="16" TextWrapping="Wrap" LineHeight="24"/>
			</StackPanel>

			<!-- FOOTER -->
			<StackPanel Spacing="8" Margin="0,64,0,0" HorizontalAlignment="Center">
				<Border Height="1" Background="{DynamicResource EnderBorder}" Margin="-1000,0,-1000,16"/>
				<StackPanel Orientation="Horizontal" Spacing="32" HorizontalAlignment="Center">
					<Button Content="GitHub" Classes="Ghost" Cursor="Hand"/>
					<Button Content="Web" Classes="Ghost" Cursor="Hand"/>
					<Button Content="etc" Classes="Ghost" Cursor="Hand"/>
				</StackPanel>
			</StackPanel>
			
		</StackPanel>
	</ScrollViewer>
</UserControl>
