<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:MCto3D.ViewModels"
		xmlns:views="using:MCto3D.Views"
		x:Class="MCto3D.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Width="{Binding WindowWidth}" Height="750" MinWidth="{Binding WindowWidth}" MinHeight="715"
		Background="{DynamicResource EnderBackgroundBase}" Foreground="{DynamicResource EnderTextPrimary}"
		ExtendClientAreaToDecorationsHint="True"
		ExtendClientAreaTitleBarHeightHint="-1"
		Icon="avares://MCto3D/Assets/Logo/Logo.ico"
		Title="MCTo3D"
		>

	<Window.Styles>
		<!-- Oculta el texto del título que dibuja Avalonia -->
		<Style Selector="WindowDrawnDecorations /template/ Panel#PART_TitleTextPanel > TextBlock">
			<Setter Property="IsVisible" Value="False" />
		</Style>
		
		<!-- Oculta el botón de Pantalla Completa (las flechas diagonales) -->
		<Style Selector="WindowDrawnDecorations /template/ Button#PART_FullScreenButton">
			<Setter Property="Opacity" Value="0" />
			<Setter Property="IsHitTestVisible" Value="False" />
		</Style>

		<Style Selector="TextBlock.SidebarText">
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="Foreground" Value="{DynamicResource EnderTextPrimary}"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>
	</Window.Styles>

	<Window.DataTemplates>
		<DataTemplate DataType="{x:Type vm:HomeViewModel}">
			<views:HomeView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:DashboardViewModel}">
			<views:DashboardView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:MyFilesViewModel}">
			<views:MyFilesView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:VanillaStructuresViewModel}">
			<views:VanillaStructuresView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:DevToolsViewModel}">
			<views:DevToolsView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:WelcomeViewModel}">
			<views:WelcomeView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:LoadingViewModel}">
			<views:LoadingView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:SettingsViewModel}">
			<views:SettingsView/>
		</DataTemplate>
		<!-- Nuevas vistas -->
		<DataTemplate DataType="{x:Type vm:LanguageSetupViewModel}">
			<views:LanguageSetupView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:WalkthroughViewModel}">
			<views:WalkthroughView/>
		</DataTemplate>
		<DataTemplate DataType="{x:Type vm:FaqViewModel}">
			<views:FaqView/>
		</DataTemplate>
	</Window.DataTemplates>

	

	<Grid RowDefinitions="Auto, *">

		<!-- Tab Border -->

		<Border Grid.Row="0" Height="30" Background="{DynamicResource EnderBackgroundBase}" IsHitTestVisible="False" BorderBrush="{DynamicResource EnderSurfaceHover}" BorderThickness="0,0,0,2">
		<!-- Placeholder for logo or title -->
				
	
	    </Border>


		<!-- MAIN LAYOUT (Sólo visible cuando no está activa la pantalla de bienvenida ni la de carga) -->
		<Grid Grid.Row="1" IsVisible="{Binding IsMainContentVisible}">
			<!-- CONTENIDO CON SPLITVIEW (Ahora ocupa toda la pantalla) -->
			<SplitView IsPaneOpen="{Binding IsSidebarExpanded}" DisplayMode="CompactInline" CompactPaneLength="70" OpenPaneLength="260" PaneBackground="{DynamicResource EnderBackgroundBase}">
				<SplitView.Pane>
					<Border BorderBrush="{DynamicResource EnderBorder}" BorderThickness="0,0,1,0" Padding="0,20">
						<Grid RowDefinitions="Auto,*,Auto">
							<!-- Sidebar Header -->
							<Grid Grid.Row="0" ColumnDefinitions="70,*" Margin="0,0,0,24">
								<Button Grid.Column="0" Command="{Binding ToggleSidebarCommand}" Classes="Ghost" Padding="0" Width="46" Height="46" CornerRadius="8" Cursor="Hand" ToolTip.Tip="Expandir/Minimizar Menú" HorizontalAlignment="Center">
									<TextBlock Text="☰" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Foreground="{DynamicResource EnderTextPrimary}"/>
								</Button>
								<!-- Title -->
								<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0" IsVisible="{Binding IsSidebarExpanded}">
									<Image Source="avares://MCto3D/Assets/Logo/Logo Rounded.png" Width="24" Height="24" Margin="0,0,8,0" />
									<TextBlock Text="{DynamicResource AppTitle}" Foreground="{DynamicResource EnderTextPrimary}" FontWeight="Black" FontSize="18" LetterSpacing="1" VerticalAlignment="Center"/>
								</StackPanel>
							</Grid>

							<!-- Top Navigation -->
							<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
								<StackPanel Spacing="8">
									<!-- Navigation Buttons -->
									<StackPanel Spacing="8">
										<!-- Home -->
										<Button Classes="Ghost" Command="{Binding NavigateToHomeCommand}" IsEnabled="{Binding !IsHomeActive}" HorizontalAlignment="Stretch" Padding="0" Height="46" Cursor="Hand">
											<Grid ColumnDefinitions="70,*">
												<TextBlock Grid.Column="0" Text="🏠" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
												<TextBlock Grid.Column="1" Classes="SidebarText" Text="{DynamicResource SidebarHome}" IsVisible="{Binding IsSidebarExpanded}"/>
											</Grid>
										</Button>
										
										<!-- Converter -->
										<Button Classes="Ghost" Command="{Binding NavigateToDashboardCommand}" IsEnabled="{Binding !IsDashboardActive}" HorizontalAlignment="Stretch" Padding="0" Height="46" Cursor="Hand">
											<Grid ColumnDefinitions="70,*">
												<TextBlock Grid.Column="0" Text="🧊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
												<TextBlock Grid.Column="1" Classes="SidebarText" Text="{DynamicResource SidebarConverter}" IsVisible="{Binding IsSidebarExpanded}"/>
											</Grid>
										</Button>
										
										<!-- My Files -->
										<Button Classes="Ghost" Command="{Binding NavigateToMyFilesCommand}" IsEnabled="{Binding !IsMyFilesActive}" HorizontalAlignment="Stretch" Padding="0" Height="46" Cursor="Hand">
											<Grid ColumnDefinitions="70,*">
												<TextBlock Grid.Column="0" Text="📁" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
												<TextBlock Grid.Column="1" Classes="SidebarText" Text="{DynamicResource SidebarMyFiles}" IsVisible="{Binding IsSidebarExpanded}"/>
											</Grid>
										</Button>

										<!-- Vanilla Structures -->
										<Button Classes="Ghost" Command="{Binding NavigateToVanillaStructuresCommand}" IsEnabled="{Binding !IsVanillaStructuresActive}" HorizontalAlignment="Stretch" Padding="0" Height="46" Cursor="Hand">
											<Grid ColumnDefinitions="70,*">
												<TextBlock Grid.Column="0" Text="🏛️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
												<TextBlock Grid.Column="1" Classes="SidebarText" Text="{DynamicResource SidebarVanillaStructures}" IsVisible="{Binding IsSidebarExpanded}"/>
											</Grid>
										</Button>
									</StackPanel>
								</StackPanel>
							</ScrollViewer>

							<!-- Bottom Navigation (Settings & DevTools) -->
							<StackPanel Grid.Row="2" Spacing="8">
								<Border Height="1" Background="{DynamicResource EnderBorder}" Margin="0,0,0,16"/>
								
								<StackPanel Spacing="8">
									
									<!-- Walkthrough 
									<Button Classes="Ghost" Command="{Binding NavigateToWalkthroughCommand}" IsEnabled="{Binding !IsWalkthroughActive}" HorizontalAlignment="Stretch" Padding="0" Height="46" Cursor="Hand">
										<Grid ColumnDefinitions="70,*">
											<TextBlock Grid.Column="0" Text="📖" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
											<TextBlock Grid.Column="1" Classes="SidebarText" Text="{DynamicResource SidebarWalkthrough}" IsVisible="{Binding IsSidebarExpanded}"/>
										</Grid>
									</Button>

									
									<Button Classes="Ghost" Command="{Binding NavigateToFaqCommand}" IsEnabled="{Binding !IsFaqActive}" HorizontalAlignment="Stretch" Padding="0" Height="46" Cursor="Hand">
										<Grid ColumnDefinitions="70,*">
											<TextBlock Grid.Column="0" Text="❓" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
											<TextBlock Grid.Column="1" Classes="SidebarText" Text="{DynamicResource SidebarFaq}" IsVisible="{Binding IsSidebarExpanded}"/>
										</Grid>
									</Button>
									-->
									<!-- Settings -->
									<Button Classes="Ghost" Command="{Binding NavigateToSettingsCommand}" IsEnabled="{Binding !IsSettingsActive}" HorizontalAlignment="Stretch" Padding="0" Height="46" Cursor="Hand">
										<Grid ColumnDefinitions="70,*">
											<TextBlock Grid.Column="0" Text="⚙️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
											<TextBlock Grid.Column="1" Classes="SidebarText" Text="{DynamicResource SidebarSettings}" IsVisible="{Binding IsSidebarExpanded}"/>
										</Grid>
									</Button>

									<!-- DevTools Button -->
									<Button Classes="Ghost" Command="{Binding NavigateToDevToolsCommand}" IsEnabled="{Binding !IsDevToolsActive}" IsVisible="{Binding IsDevelopmentMode}" HorizontalAlignment="Stretch" Padding="0" Height="46" Cursor="Hand">
										<Grid ColumnDefinitions="70,*">
											<TextBlock Grid.Column="0" Text="🛠️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
											<TextBlock Grid.Column="1" Classes="SidebarText" Text="{DynamicResource SidebarDevTools}" IsVisible="{Binding IsSidebarExpanded}"/>
										</Grid>
									</Button>
								</StackPanel>
							</StackPanel>

                            <!-- OVERLAY: Prevents clicks while moving files but does not disable the UI style -->
                            <Border Grid.RowSpan="3" Background="Transparent" ZIndex="100" IsVisible="{Binding SettingsVM.IsMovingFiles}"/>
						</Grid>
					</Border>
				</SplitView.Pane>

				<SplitView.Content>
					<ContentControl Content="{Binding CurrentPage}" />
				</SplitView.Content>
			</SplitView>
		</Grid>

		<!-- OVERLAY PANTALLA DE BIENVENIDA -->
		<ContentControl Grid.Row="1" Content="{Binding WelcomeVM}" IsVisible="{Binding IsWelcomeScreenActive}"/>

		<!-- OVERLAY PANTALLA DE CONFIGURACION DE IDIOMA -->
		<ContentControl Grid.Row="1" Content="{Binding LanguageSetupVM}" IsVisible="{Binding IsLanguageSetupActive}"/>

		<!-- OVERLAY PANTALLA DE CARGA GLOBAL -->
		<ContentControl Grid.Row="1" Content="{Binding LoadingVM}" IsVisible="{Binding LoadingVM.IsActive}"/>
	</Grid>
</Window>