<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:MCto3D.ViewModels"
			 xmlns:models="using:MCto3D.Models"
			 xmlns:controls="using:MCto3D.Controls"
			 xmlns:conv="using:MCto3D.Converters"
			 x:Class="MCto3D.Views.DashboardView"
			 x:DataType="vm:DashboardViewModel">

	<UserControl.Resources>
		<conv:SelectedThumbnailConverter x:Key="SelectedThumbnailConverter" />
	</UserControl.Resources>

	<UserControl.Styles>
		<!-- Tab Items -->

		<Style Selector="TabControl /template/ ItemsPresenter#PART_ItemsPresenter">
			<Setter Property="ZIndex" Value="1" />
		</Style>

		<Style Selector="TextBlock.SettingsLabel">
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="Foreground" Value="{DynamicResource EnderTextSecondary}"/>
			<Setter Property="FontWeight" Value="Medium"/>
		</Style>

		<!-- Global -->
		<Style Selector="TabItem">
			<Setter Property="Background" Value="{DynamicResource EnderBackground}"/>
			<Setter Property="Foreground" Value="{DynamicResource EnderTextPrimary}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource EnderBorder}"/>
			<Setter Property="BorderThickness" Value="2,2,2,0"/>
			<Setter Property="CornerRadius" Value="6,6,0,0"/>
			<Setter Property="Margin" Value="0,0,0,-4"/>
			<Setter Property="FontSize" Value="18"/>
		</Style>

		<!-- Hovering -->
		<Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
			<Setter Property="Background" Value="{DynamicResource EnderSurface}"/>
		</Style>

		<!-- Selected -->
		<Style Selector="TabItem:selected /template/ Border#PART_LayoutRoot">
			<Setter Property="Background" Value="{DynamicResource EnderSurface}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource EnderPrimary}"/>
			<Setter Property="BorderThickness" Value="2,2,2,0"/>
			<Setter Property="CornerRadius" Value="6,6,0,0"/>
		</Style>

		<!-- Disabled -->
		<Style Selector="TabItem:disabled">
			<Setter Property="Foreground" Value="{DynamicResource EnderTextSecondary}"/>
		</Style>

		<Style Selector="TabItem:disabled /template/ Border#PART_LayoutRoot">
			<Setter Property="Background" Value="{DynamicResource EnderDisabled}"/>
		</Style>
	</UserControl.Styles>

	<Grid Margin="32" RowDefinitions="Auto,*">
		<!-- HEADER -->
		<Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,24">
			<TextBlock Grid.Column="1" Classes="H1" Text="{DynamicResource ConverterTitle}" VerticalAlignment="Center"/>
		</Grid>

		<Grid Grid.Row="1" ColumnDefinitions="*,*">
			<!-- Columna Izquierda (Centro de App): Configuraciones / Archivo -->
			<ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,32,0">
				<StackPanel Spacing="24">

					<!-- Estado: No hay archivo cargado -->
					<Border Classes="Card" Padding="40,48" IsVisible="{Binding !IsFileLoaded}">
						<StackPanel Spacing="16" HorizontalAlignment="Center">
							<TextBlock Text="📁" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,8"/>
							<TextBlock Classes="H3" Text="{DynamicResource ConverterNoFileTitle}" HorizontalAlignment="Center"/>
							<TextBlock Classes="Subtitle" Text="{DynamicResource ConverterNoFileDesc}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,-4,0,8"/>
							<Button Content="{DynamicResource ConverterSelectFileBtn}"
									Command="{Binding LoadFileCommand}"
									CommandParameter="{Binding $parent[UserControl]}"
									Classes="Primary" Padding="32,16" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					<TextBlock Text="{DynamicResource ConverterAdmittedTypes}" Foreground="{DynamicResource EnderTextSecondary}" FontSize="14" HorizontalAlignment="Center" IsVisible="{Binding !IsFileLoaded}"/>

					<!-- Estado: Archivo Cargado -->

					<StackPanel Orientation="Horizontal" Spacing="24">
						<Border Classes="Card" Padding="20"  BorderBrush="{DynamicResource EnderPrimary}" IsVisible="{Binding IsFileLoaded}">
							<Grid ColumnDefinitions="Auto,*,Auto">
								<TextBlock Grid.Column="0" Text="📄" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
								<StackPanel Grid.Column="1" VerticalAlignment="Center">
									<TextBlock Classes="Subtitle" FontWeight="SemiBold" Text="{DynamicResource ConverterActiveFile}"/>
									<TextBlock Classes="H3" Text="{Binding OriginalFileName}" TextTrimming="CharacterEllipsis"/>
								</StackPanel>
								<Button Grid.Column="2" Content="✕"
										Command="{Binding CancelFileCommand}"
										Classes="Ghost" Padding="12,8" VerticalAlignment="Center" ToolTip.Tip="Cancelar archivo"/>
							</Grid>
						</Border>
					</StackPanel>

					<StackPanel Orientation="Horizontal" Spacing="24" IsVisible="{Binding IsFileLoaded}" >

						<TabControl Classes="converter" TabStripPlacement="Top" Padding="0">
							<!-- File Settings -->
							<TabItem Classes="converter" Header="{DynamicResource Converter3DModel}">
								<Border Classes="Card" Padding="24" MinWidth="450" VerticalAlignment="Top" CornerRadius="0,10,10,10">
									<Grid RowDefinitions="*,Auto">
										<!-- Ajustes scrolleables -->
										<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
											<StackPanel Spacing="16">
												<TextBlock Classes="H3" Text="{DynamicResource ConverterMeshSettings}" Margin="0,0,0,8"/>

												<Grid ColumnDefinitions="160,*">
													<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource ConverterOutFormat}"/>
													<ComboBox Grid.Column="1" HorizontalAlignment="Stretch" SelectedItem="{Binding ExportVM.ExportFormat}">
														<x:String>STL</x:String>
														<x:String>3MF</x:String>
													</ComboBox>
												</Grid>


												<StackPanel IsVisible="{Binding FillHoles}" Margin="0,8,0,0">
													<!-- Custom fill color logic: only relevant if not in single color mode -->
													<StackPanel Spacing="12" IsVisible="{Binding PaletteVM.SelectedAlgorithm, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter={x:Static models:ColorAlgorithm.SingleColor}}">
														<Grid ColumnDefinitions="160,*">
															<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource ConverterFillColor}"/>
															<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
																<CheckBox Content="{DynamicResource ConverterUseCustom}" IsChecked="{Binding UseCustomFillColor}" VerticalAlignment="Center" Foreground="{DynamicResource EnderTextPrimary}"/>
																<ColorPicker IsVisible="{Binding UseCustomFillColor}" Color="{Binding CustomFillColor}" Height="32" VerticalAlignment="Center"/>
															</StackPanel>
														</Grid>
													</StackPanel>
												</StackPanel>

												<!-- Botón extra o espacio extra si es necesario -->

											</StackPanel>
										</ScrollViewer>

										<!-- Botones de Acción Integrados Fijos al Fondo -->
										<StackPanel Grid.Row="1" Spacing="8" Margin="0,16,0,0">
											<Border Height="1" Background="{DynamicResource EnderBorder}" Margin="0,0,0,8"/>
											<Grid ColumnDefinitions="*,*">
												<SplitButton Grid.Column="0" Content="{Binding ExportVM.SelectedSlicer.ButtonText}"
															 Command="{Binding ExportVM.OpenInSlicerCommand}"
															 Background="{Binding ExportVM.SelectedSlicer.ColorHex}"
															 Foreground="White"
															 Padding="12,10"
															 CornerRadius="8"
															 Cursor="Hand"
															 FontWeight="SemiBold"
															 Margin="0,0,8,0"
															 HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
													<SplitButton.Flyout>
														<MenuFlyout Placement="BottomEdgeAlignedRight">
															<MenuItem Header="OrcaSlicer" Command="{Binding ExportVM.ChangeSlicerCommand}" CommandParameter="{Binding ExportVM.SlicerOptions[0]}">
																<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#027D52"/></MenuItem.Icon>
															</MenuItem>
															<MenuItem Header="BambuStudio" Command="{Binding ExportVM.ChangeSlicerCommand}" CommandParameter="{Binding ExportVM.SlicerOptions[1]}">
																<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#00AE42"/></MenuItem.Icon>
															</MenuItem>
															<MenuItem Header="PrusaSlicer" Command="{Binding ExportVM.ChangeSlicerCommand}" CommandParameter="{Binding ExportVM.SlicerOptions[2]}">
																<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#EA6B24"/></MenuItem.Icon>
															</MenuItem>
															<MenuItem Header="Cura" Command="{Binding ExportVM.ChangeSlicerCommand}" CommandParameter="{Binding ExportVM.SlicerOptions[3]}">
																<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#0055FF"/></MenuItem.Icon>
															</MenuItem>
														</MenuFlyout>
													</SplitButton.Flyout>
												</SplitButton>

												<Button Grid.Column="1" Content="{DynamicResource ConverterExportLocal}"
														Command="{Binding ExportVM.ExportFileCommand}"
														CommandParameter="{Binding $parent[UserControl]}"
														Background="{DynamicResource EnderSecondary}" Foreground="White" FontWeight="Bold"
														HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
														Padding="12,10" CornerRadius="8" Cursor="Hand" Margin="8,0,0,0"/>
											</Grid>

											<Button Content="{DynamicResource ConverterSaveApp}"
													Command="{Binding ProjectSaveVM.OpenSavePopupCommand}"
													Classes="Primary"
													HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
													Padding="12,10"/>

											<!-- Estado de Progreso -->
											<TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource EnderSecondary}" FontWeight="Medium" FontSize="12" HorizontalAlignment="Center"/>
										</StackPanel>
									</Grid>
								</Border>


							</TabItem>

							<TabItem Classes="converter" Header="{DynamicResource ConverterGeometryOptions}" >
								<Border Classes="Card" Padding="24" MinWidth="350" VerticalAlignment="Top">
									<ScrollViewer VerticalScrollBarVisibility="Auto">
										<StackPanel Spacing="16">
											<TextBlock Classes="H3" Text="{DynamicResource ConverterGeometryOptions}" Margin="0,0,0,8"/>

											<Grid ColumnDefinitions="160,*">
												<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource ConverterBlockScale}"/>
												<NumericUpDown Grid.Column="1" Value="{Binding Bs}" Minimum="0.01" Maximum="10" Increment="0.05" HorizontalAlignment="Stretch"/>
											</Grid>
											<Grid ColumnDefinitions="160,*">
												<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource ConverterGeomMode}"/>
												<ComboBox Grid.Column="1" HorizontalAlignment="Stretch" SelectedIndex="{Binding SelectedGeometryModeIndex}">
													<ComboBoxItem Content="{DynamicResource ConverterGeomSolid}" />
													<ComboBoxItem Content="{DynamicResource ConverterGeomFull}" />
												</ComboBox>
											</Grid>

											<!-- Llenar Huecos -->
											<Grid ColumnDefinitions="160,*" Margin="0,8,0,0">
												<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource ConverterFillHoles}"/>
												<ToggleSwitch Grid.Column="1" IsChecked="{Binding FillHoles}" OnContent="{DynamicResource GlobalYes}" OffContent="{DynamicResource GlobalNo}" />
											</Grid>
										</StackPanel>
									</ScrollViewer>
								</Border>
							</TabItem>
							<TabItem Classes="converter" Header="{DynamicResource Converter3MfOptions}" IsEnabled="{Binding ExportVM.Is3MfSelected}" ToolTip.Tip="{DynamicResource Converter3MfNotSelected}" ToolTip.ShowOnDisabled="{Binding !ExportVM.Is3MfSelected}" >
								<Border Classes="Card" Padding="24" MinWidth="350" VerticalAlignment="Top">
									<ScrollViewer VerticalScrollBarVisibility="Auto">
										<StackPanel Spacing="16">
											<TextBlock Classes="H3" Text="{DynamicResource Converter3MfOptions}" Margin="0,0,0,8"/>

											<Grid ColumnDefinitions="160,*">
												<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource ConverterAlgorithm}"/>
												<ComboBox Grid.Column="1" HorizontalAlignment="Stretch" SelectedIndex="{Binding PaletteVM.SelectedAlgorithm}">
													<ComboBoxItem Content="{DynamicResource ConverterMono}" />
													<ComboBoxItem Content="{DynamicResource ConverterCustomPalette}" />
													<ComboBoxItem Content="{DynamicResource ConverterKMeansAvg}" />
													<ComboBoxItem Content="{DynamicResource ConverterKMedoids}" />
													<ComboBoxItem Content="{DynamicResource ConverterRawColors}" />
												</ComboBox>
											</Grid>

											<Border Height="1" Background="{DynamicResource EnderBorder}" Margin="0,8"/>

											<StackPanel IsVisible="{Binding PaletteVM.SelectedAlgorithm, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter={x:Static models:ColorAlgorithm.SingleColor}}" Spacing="16">

												<Grid ColumnDefinitions="160,*" IsVisible="{Binding PaletteVM.SelectedAlgorithm, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:ColorAlgorithm.RawColors}}">
													<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource ConverterInfo}"/>
													<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
														<TextBlock Text="{DynamicResource ConverterColorCount}" Foreground="{DynamicResource EnderTextPrimary}" FontWeight="Bold"/>
														<TextBlock Text="{Binding RawColorCount}" Foreground="{DynamicResource EnderTextPrimary}" FontWeight="Bold"/>
													</StackPanel>
												</Grid>

												<Grid ColumnDefinitions="160,*" IsVisible="{Binding PaletteVM.SelectedAlgorithm, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:ColorAlgorithm.KMeans}}">
													<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource ConverterAmountK}"/>
													<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
														<Slider Minimum="2" Maximum="16" Value="{Binding PaletteVM.KMeansCount}" Width="120" VerticalAlignment="Center"/>
														<TextBlock Text="{Binding PaletteVM.KMeansCount}" Foreground="{DynamicResource EnderTextPrimary}" VerticalAlignment="Center" FontWeight="Bold" Width="20"/>
													</StackPanel>
												</Grid>

												<Grid ColumnDefinitions="160,*" IsVisible="{Binding PaletteVM.SelectedAlgorithm, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:ColorAlgorithm.KMedoids}}">
													<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource ConverterAmountK}"/>
													<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
														<Slider Minimum="2" Maximum="16" Value="{Binding PaletteVM.KMeansCount}" Width="120" VerticalAlignment="Center"/>
														<TextBlock Text="{Binding PaletteVM.KMeansCount}" Foreground="{DynamicResource EnderTextPrimary}" VerticalAlignment="Center" FontWeight="Bold" Width="20"/>
													</StackPanel>
												</Grid>

												<Grid ColumnDefinitions="160,*" IsVisible="{Binding PaletteVM.SelectedAlgorithm, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static models:ColorAlgorithm.Palette}}">
													<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource ConverterPalette}" Margin="0,8,0,0" VerticalAlignment="Top"/>
													<StackPanel Grid.Column="1" Spacing="16">
														<ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding PaletteVM.AvailablePalettes}" SelectedItem="{Binding PaletteVM.SelectedPalette}">
															<ComboBox.ItemTemplate>
																<DataTemplate>
																	<TextBlock Text="{Binding Name}" />
																</DataTemplate>
															</ComboBox.ItemTemplate>
														</ComboBox>

														<!-- Guardadas -->
														<StackPanel Spacing="8" IsVisible="{Binding PaletteVM.IsSavedPaletteSelected}">
															<TextBox Classes="Modern" Text="{Binding PaletteVM.SelectedPaletteNameInput}" PlaceholderText="{DynamicResource ConverterOptionalName}" />
															<ItemsControl ItemsSource="{Binding PaletteVM.UserDefinedColors}">
																<ItemsControl.ItemTemplate>
																	<DataTemplate>
																		<StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
																			<ColorPicker Color="{Binding Color}" Height="32"/>
																			<Button Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).PaletteVM.RemoveUserColorCommand}" CommandParameter="{Binding}" Classes="Ghost" Padding="8">
																				<TextBlock Text="🗑️" FontSize="14"/>
																			</Button>
																		</StackPanel>
																	</DataTemplate>
																</ItemsControl.ItemTemplate>
															</ItemsControl>
															<Button Content="{DynamicResource ConverterAddColor}" Command="{Binding PaletteVM.AddUserColorCommand}" Classes="Ghost" HorizontalAlignment="Left" Foreground="{DynamicResource EnderPrimary}" Padding="8,4"/>
															<StackPanel Orientation="Horizontal" Spacing="8">
																<Button Content="{DynamicResource GlobalUpdate}" Command="{Binding PaletteVM.UpdateSavedPaletteCommand}" IsVisible="{Binding PaletteVM.HasUnsavedPaletteChanges}" Classes="Primary"/>
																<Button Content="{DynamicResource GlobalDelete}" Command="{Binding PaletteVM.DeleteSavedPaletteCommand}" Background="#EF4444" Foreground="White" FontWeight="Bold"/>
															</StackPanel>
														</StackPanel>

														<!-- Personalizada (Nueva) -->
														<StackPanel Spacing="8" IsVisible="{Binding PaletteVM.IsCustomPaletteSelected}">
															<TextBox Classes="Modern" Text="{Binding PaletteVM.NewPaletteName}" PlaceholderText="{DynamicResource ConverterOptionalName}" />
															<ItemsControl ItemsSource="{Binding PaletteVM.UserDefinedColors}">
																<ItemsControl.ItemTemplate>
																	<DataTemplate>
																		<StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
																			<ColorPicker Color="{Binding Color}" Height="32"/>
																			<Button Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).PaletteVM.RemoveUserColorCommand}" CommandParameter="{Binding}" Classes="Ghost" Padding="8">
																				<TextBlock Text="🗑️" FontSize="14"/>
																			</Button>
																		</StackPanel>
																	</DataTemplate>
																</ItemsControl.ItemTemplate>
															</ItemsControl>
															<Button Content="{DynamicResource ConverterAddColor}" Command="{Binding PaletteVM.AddUserColorCommand}" Classes="Ghost" HorizontalAlignment="Left" Foreground="{DynamicResource EnderPrimary}" Padding="8,4"/>
															<Button Content="{DynamicResource GlobalSave}" Command="{Binding PaletteVM.SaveCustomPaletteCommand}" CommandParameter="{Binding PaletteVM.NewPaletteName}" Classes="Primary" HorizontalAlignment="Left"/>
														</StackPanel>
													</StackPanel>
												</Grid>
											</StackPanel>
										</StackPanel>
									</ScrollViewer>
								</Border>
							</TabItem>

						</TabControl>

					</StackPanel>
				</StackPanel>
			</ScrollViewer>


			<!-- Columna Derecha: Renderizado-->
			<Border Grid.Column="1" Classes="Card" Padding="20" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
				<Panel>
					<Border IsVisible="{Binding !IsFileLoaded}" HorizontalAlignment="Center" VerticalAlignment="Center">
						<TextBlock Text="{DynamicResource ConverterFutureWorldReading}" TextWrapping="Wrap" Foreground="{DynamicResource EnderBorder}" FontSize="24" FontWeight="Black" />
					</Border>

					<!-- Loaded State: Render -->
					<Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding IsFileLoaded}">
						<Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
							<TextBlock Grid.Column="0" Classes="H3" Text="{DynamicResource ConverterInteractiveViewer}" VerticalAlignment="Center"/>
							<Border Grid.Column="1" Background="#10B98120" Padding="8,4" CornerRadius="4">
								<TextBlock Text="{DynamicResource ConverterLiveRender}" Foreground="{DynamicResource EnderSecondary}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
							</Border>
						</Grid>
						<Border Grid.Row="1" Background="{DynamicResource EnderSurfaceHover}" CornerRadius="8" BorderBrush="{DynamicResource EnderBorder}" BorderThickness="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="True">
							<Grid Background="Transparent">
								<controls:MinecraftRenderControl x:Name="MainRenderControl" Triangles="{Binding MeshTriangles}" ColoredMeshes="{Binding ColoredMeshes}" AutoRotate="False" ShowFloor="{Binding ShowFloor}" FloorColor="{Binding FloorColor}" OverrideModelColor="{Binding PaletteVM.IsSingleColorMode}" ModelColor="{Binding ModelColor}"/>


								<!-- Controles Superpuestos -->
								<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="16" Opacity="0.6" IsHitTestVisible="False">
									<TextBlock Text="🖱️" FontSize="16" Foreground="{DynamicResource EnderTextSecondary}" VerticalAlignment="Center"/>
									<TextBlock Text="zoom" FontSize="14" Foreground="{DynamicResource EnderTextSecondary}" VerticalAlignment="Center" FontFamily="Comic Sans MS, Cursive"/>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="16" Opacity="0.6" IsHitTestVisible="False">
									<TextBlock Text="🖱️" FontSize="16" Foreground="{DynamicResource EnderTextSecondary}" VerticalAlignment="Center"/>
									<TextBlock Text="rotate" FontSize="14" Foreground="{DynamicResource EnderTextSecondary}" VerticalAlignment="Center" FontFamily="Comic Sans MS, Cursive"/>
								</StackPanel>

								<!-- OVERLAY DE CARGA -->
								<Border Background="#D00B0B13" IsVisible="{Binding IsLoadingMesh}">
									<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
										<TextBlock Text="{DynamicResource ConverterGeneratingMesh}" Foreground="{DynamicResource EnderPrimary}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
										<ProgressBar IsIndeterminate="True" Foreground="{DynamicResource EnderPrimary}" Background="{DynamicResource EnderSurfaceHover}" HorizontalAlignment="Stretch" MinWidth="150"/>
										<TextBlock Classes="Subtitle" Text="{DynamicResource ConverterWaitMsg}" HorizontalAlignment="Center"/>
									</StackPanel>
								</Border>
							</Grid>
						</Border>

						<!-- Floor Toggle Controls -->
						<StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,16,0,0">
							<TextBlock Text="{DynamicResource SettingsRendererFloor}" VerticalAlignment="Center" Foreground="{DynamicResource EnderTextSecondary}" FontWeight="Medium"/>
							<CheckBox IsChecked="{Binding ShowFloor}" Foreground="{DynamicResource EnderTextPrimary}"/>
							<ColorPicker Color="{Binding FloorColor}" IsVisible="{Binding ShowFloor}" Height="32"/>
						</StackPanel>
					</Grid>
				</Panel>
			</Border>
		</Grid>

		<!-- OVERLAY POPUP: Guardar Proyecto -->
		<Border Grid.RowSpan="2" Background="#D0000000" IsVisible="{Binding ProjectSaveVM.IsSavePopupOpen}" ZIndex="100" Margin="-32">
			<Border Classes="Card" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="800">
				<Grid ColumnDefinitions="*,*">

					<!-- Columna Izquierda: Input y Botones -->
					<StackPanel Grid.Column="0" Spacing="24" Margin="0,0,32,0" VerticalAlignment="Center">
						<TextBlock Classes="H2" Text="{DynamicResource ConverterSavePopupTitle}"/>
						<TextBlock Classes="Subtitle" Text="{DynamicResource ConverterSavePopupDesc}" TextWrapping="Wrap"/>

						<TextBox Classes="Modern" FontSize="16" Text="{Binding ProjectSaveVM.NewProjectName}" PlaceholderText="{DynamicResource ConverterSavePopupPlaceholder}"/>

						<Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
							<Button Grid.Column="0" Content="{DynamicResource ConverterCancelBtn}" Command="{Binding ProjectSaveVM.CloseSavePopupCommand}" Classes="Ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,14" Margin="0,0,8,0"/>
							<Button Grid.Column="1" Content="{DynamicResource ConverterSaveBtn}" Command="{Binding ProjectSaveVM.ConfirmSaveToAppCommand}" Classes="Primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,14" Margin="8,0,0,0"/>
						</Grid>
					</StackPanel>

					<!-- Columna Derecha: Selección de Miniaturas (Grid 2x2) -->
					<Grid Grid.Column="1" RowDefinitions="*,*" ColumnDefinitions="*,*" RowSpacing="16" ColumnSpacing="16" Height="300" Width="300">
						<!-- Img 1 (0) -->
						<Button Grid.Row="0" Grid.Column="0" Padding="0" CornerRadius="8" Command="{Binding ProjectSaveVM.SelectThumbnailCommand}" CommandParameter="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent">
							<Border BorderBrush="{Binding ProjectSaveVM.SelectedThumbnailIndex, Converter={StaticResource SelectedThumbnailConverter}, ConverterParameter=0}" BorderThickness="3" CornerRadius="8" ClipToBounds="True">
								<Image Source="{Binding ProjectSaveVM.Thumbnails[0]}" Stretch="UniformToFill"/>
							</Border>
						</Button>

						<!-- Img 2 (1) -->
						<Button Grid.Row="0" Grid.Column="1" Padding="0" CornerRadius="8" Command="{Binding ProjectSaveVM.SelectThumbnailCommand}" CommandParameter="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent">
							<Border BorderBrush="{Binding ProjectSaveVM.SelectedThumbnailIndex, Converter={StaticResource SelectedThumbnailConverter}, ConverterParameter=1}" BorderThickness="3" CornerRadius="8" ClipToBounds="True">
								<Image Source="{Binding ProjectSaveVM.Thumbnails[1]}" Stretch="UniformToFill"/>
							</Border>
						</Button>

						<!-- Img 3 (2) -->
						<Button Grid.Row="1" Grid.Column="0" Padding="0" CornerRadius="8" Command="{Binding ProjectSaveVM.SelectThumbnailCommand}" CommandParameter="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent">
							<Border BorderBrush="{Binding ProjectSaveVM.SelectedThumbnailIndex, Converter={StaticResource SelectedThumbnailConverter}, ConverterParameter=2}" BorderThickness="3" CornerRadius="8" ClipToBounds="True">
								<Image Source="{Binding ProjectSaveVM.Thumbnails[2]}" Stretch="UniformToFill"/>
							</Border>
						</Button>

						<!-- Img 4 (3) -->
						<Button Grid.Row="1" Grid.Column="1" Padding="0" CornerRadius="8" Command="{Binding ProjectSaveVM.SelectThumbnailCommand}" CommandParameter="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent">
							<Border BorderBrush="{Binding ProjectSaveVM.SelectedThumbnailIndex, Converter={StaticResource SelectedThumbnailConverter}, ConverterParameter=3}" BorderThickness="3" CornerRadius="8" ClipToBounds="True">
								<Image Source="{Binding ProjectSaveVM.Thumbnails[3]}" Stretch="UniformToFill"/>
							</Border>
						</Button>
					</Grid>

				</Grid>
			</Border>
		</Border>
	</Grid>
