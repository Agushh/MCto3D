<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:MCto3D.ViewModels"
			 xmlns:controls="using:MCto3D.Controls"
			 xmlns:conv="using:MCto3D.Converters"
			 x:Class="MCto3D.Views.DashboardView"
			 x:DataType="vm:DashboardViewModel">

	<UserControl.Resources>
		<conv:SelectedThumbnailConverter x:Key="SelectedThumbnailConverter" />
	</UserControl.Resources>

	<Grid Margin="32" RowDefinitions="Auto,*">
		<!-- HEADER -->
		<Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0,0,0,24">
			<Button Grid.Column="0" Command="{Binding GoBackCommand}" Classes="Ghost" Padding="12,8" Margin="0,0,16,0" VerticalAlignment="Center">
				<TextBlock Text="←" VerticalAlignment="Center" FontSize="20"/>
			</Button>
			<TextBlock Grid.Column="1" Text="{DynamicResource ConverterTitle}" FontSize="28" FontWeight="Black" Foreground="{DynamicResource EnderTextPrimary}" VerticalAlignment="Center"/>
		</Grid>

		<Grid Grid.Row="1" ColumnDefinitions="*,400">
			<!-- Columna Izquierda (Centro de App): Configuraciones / Archivo -->
			<ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,32,0">
				<StackPanel Spacing="24">
					
					<!-- Estado: No hay archivo cargado -->
					<Border Classes="Card" Padding="40,48" IsVisible="{Binding !IsFileLoaded}">
						<StackPanel Spacing="16" HorizontalAlignment="Center">
							<TextBlock Text="📁" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,8"/>
							<TextBlock Text="{DynamicResource ConverterNoFileTitle}" Foreground="{DynamicResource EnderTextPrimary}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
							<TextBlock Text="{DynamicResource ConverterNoFileDesc}" Foreground="{DynamicResource EnderTextSecondary}" FontSize="12" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,-4,0,8"/>
							<Button Content="{DynamicResource ConverterSelectFileBtn}"
									Command="{Binding LoadFileCommand}"
									CommandParameter="{Binding $parent[UserControl]}"
									Classes="Primary" Padding="32,16" HorizontalAlignment="Center"/>
						</StackPanel>
					</Border>
					<TextBlock Text="{DynamicResource ConverterAdmittedTypes}" Foreground="{DynamicResource EnderTextSecondary}" FontSize="14" HorizontalAlignment="Center" IsVisible="{Binding !IsFileLoaded}"/>

					<!-- Estado: Archivo Cargado -->
					<Border Classes="Card" Padding="20" BorderBrush="{DynamicResource EnderPrimary}" IsVisible="{Binding IsFileLoaded}">
						<Grid ColumnDefinitions="Auto,*,Auto">
							<TextBlock Grid.Column="0" Text="📄" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
							<StackPanel Grid.Column="1" VerticalAlignment="Center">
								<TextBlock Text="{DynamicResource ConverterActiveFile}" FontSize="12" Foreground="{DynamicResource EnderTextSecondary}" FontWeight="SemiBold"/>
								<TextBlock Text="{Binding OriginalFileName}" FontSize="16" Foreground="{DynamicResource EnderTextPrimary}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
							</StackPanel>
							<Button Grid.Column="2" Content="✕" 
									Command="{Binding CancelFileCommand}" 
									Classes="Ghost" Padding="12,8" VerticalAlignment="Center" ToolTip.Tip="Cancelar archivo"/>
						</Grid>
					</Border>

					<!-- Controles de Geometría (Solo visibles si hay archivo) -->
					<Border Classes="Card" Padding="24" IsVisible="{Binding IsFileLoaded}">
						<Grid RowDefinitions="*,Auto">
							<!-- Ajustes scrolleables -->
							<ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
								<StackPanel Spacing="16">
									<TextBlock Text="{DynamicResource ConverterMeshSettings}" FontWeight="Bold" Foreground="{DynamicResource EnderTextPrimary}" FontSize="16" Margin="0,0,0,8"/>
							
							<Grid ColumnDefinitions="160,*">
								<TextBlock Grid.Column="0" Text="{DynamicResource ConverterBlockScale}" VerticalAlignment="Center" Foreground="{DynamicResource EnderTextSecondary}" FontWeight="Medium"/>
								<NumericUpDown Grid.Column="1" Value="{Binding Bs}" Minimum="0.01" Maximum="10" Increment="0.05" HorizontalAlignment="Stretch"/>
							</Grid>

							<Grid ColumnDefinitions="160,*">
								<TextBlock Grid.Column="0" Text="{DynamicResource ConverterGeomMode}" VerticalAlignment="Center" Foreground="{DynamicResource EnderTextSecondary}" FontWeight="Medium"/>
								<ComboBox Grid.Column="1" HorizontalAlignment="Stretch" SelectedItem="{Binding GeometryMode}">
									<x:String>Bloques sólidos</x:String>
									<x:String>Geometrías completas</x:String>
								</ComboBox>
							</Grid>

							<Grid ColumnDefinitions="160,*">
								<TextBlock Grid.Column="0" Text="{DynamicResource ConverterOutFormat}" VerticalAlignment="Center" Foreground="{DynamicResource EnderTextSecondary}" FontWeight="Medium"/>
								<ComboBox Grid.Column="1" HorizontalAlignment="Stretch" SelectedItem="{Binding ExportFormat}">
									<x:String>STL</x:String>
									<x:String>3MF</x:String>
								</ComboBox>
							</Grid>

							<Grid ColumnDefinitions="160,*" IsVisible="{Binding Is3MfSelected}">
								<TextBlock Grid.Column="0" Text="{DynamicResource ConverterColorMgmt}" VerticalAlignment="Center" Foreground="{DynamicResource EnderTextSecondary}" FontWeight="Medium"/>
								<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
									<RadioButton Content="{DynamicResource ConverterMono}" IsChecked="{Binding IsSingleColorMode}" Foreground="{DynamicResource EnderTextPrimary}"/>
									<RadioButton Content="{DynamicResource ConverterMulti}" IsChecked="{Binding IsMultiColorMode}" Foreground="{DynamicResource EnderTextPrimary}"/>
								</StackPanel>
							</Grid>

							<!-- Ajustes de Modelo 3D -->
							<Grid ColumnDefinitions="160,*">
								<TextBlock Grid.Column="0" Text="{DynamicResource Converter3DModel}" VerticalAlignment="Center" Foreground="{DynamicResource EnderTextSecondary}" FontWeight="Medium"/>
								<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
									<CheckBox Content="{DynamicResource ConverterForceColor}" IsChecked="{Binding OverrideModelColor}" Foreground="{DynamicResource EnderTextPrimary}"/>
									<ColorPicker Color="{Binding ModelColor}" IsVisible="{Binding OverrideModelColor}" Height="32"/>
								</StackPanel>
							</Grid>

							<!-- Ajustes de Suelo -->
							<Grid ColumnDefinitions="160,*">
								<TextBlock Grid.Column="0" Text="{DynamicResource ConverterScene}" VerticalAlignment="Center" Foreground="{DynamicResource EnderTextSecondary}" FontWeight="Medium"/>
								<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
									<CheckBox Content="{DynamicResource ConverterAddFloor}" IsChecked="{Binding ShowFloor}" Foreground="{DynamicResource EnderTextPrimary}"/>
									<ColorPicker Color="{Binding FloorColor}" IsVisible="{Binding ShowFloor}" Height="32"/>
								</StackPanel>
							</Grid>

								</StackPanel>
							</ScrollViewer>

							<!-- Botones de Acción Integrados Fijos al Fondo -->
							<StackPanel Grid.Row="1" Spacing="8" Margin="0,16,0,0">
								<Border Height="1" Background="{DynamicResource EnderBorder}" Margin="0,0,0,8"/>
								<Grid ColumnDefinitions="*,*">
									<SplitButton Grid.Column="0" Content="{Binding SelectedSlicer.ButtonText}"
												 Command="{Binding OpenInSlicerCommand}"
												 Background="{Binding SelectedSlicer.ColorHex}"
												 Foreground="White"
												 Padding="12,10"
												 CornerRadius="8"
												 Cursor="Hand"
												 FontWeight="SemiBold"
												 Margin="0,0,8,0"
												 HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
										<SplitButton.Flyout>
											<MenuFlyout Placement="BottomEdgeAlignedRight">
												<MenuItem Header="OrcaSlicer" Command="{Binding ChangeSlicerCommand}" CommandParameter="{Binding SlicerOptions[0]}">
													<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#027D52"/></MenuItem.Icon>
												</MenuItem>
												<MenuItem Header="BambuStudio" Command="{Binding ChangeSlicerCommand}" CommandParameter="{Binding SlicerOptions[1]}">
													<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#00AE42"/></MenuItem.Icon>
												</MenuItem>
												<MenuItem Header="PrusaSlicer" Command="{Binding ChangeSlicerCommand}" CommandParameter="{Binding SlicerOptions[2]}">
													<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#EA6B24"/></MenuItem.Icon>
												</MenuItem>
												<MenuItem Header="Cura" Command="{Binding ChangeSlicerCommand}" CommandParameter="{Binding SlicerOptions[3]}">
													<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#0055FF"/></MenuItem.Icon>
												</MenuItem>
											</MenuFlyout>
										</SplitButton.Flyout>
									</SplitButton>

									<Button Grid.Column="1" Content="{DynamicResource ConverterExportLocal}" 
											Command="{Binding ExportFileCommand}" 
											CommandParameter="{Binding $parent[UserControl]}"
											Background="{DynamicResource EnderSecondary}" Foreground="White" FontWeight="Bold" 
											HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
											Padding="12,10" CornerRadius="8" Cursor="Hand" Margin="8,0,0,0"/>
								</Grid>
								
								<Button Content="{DynamicResource ConverterSaveApp}" 
										Command="{Binding OpenSavePopupCommand}" 
										Classes="Primary"
										HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
										Padding="12,10"/>

								<!-- Estado de Progreso -->
								<TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource EnderSecondary}" FontWeight="Medium" FontSize="12" HorizontalAlignment="Center"/>
							</StackPanel>
						</Grid>
					</Border>
				</StackPanel>
			</ScrollViewer>

			<!-- Columna Derecha: Renderizado Fijo o Ads -->
			<Border Grid.Column="1" Classes="Card" Padding="20" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
				<Panel>
					<!-- Empty State: Future Ads -->
					<Border IsVisible="{Binding !IsFileLoaded}" HorizontalAlignment="Center" VerticalAlignment="Center">
						<!-- Rotate to vertical to match mockup -->
						<TextBlock Text="{DynamicResource ConverterFutureAds}" Foreground="{DynamicResource EnderBorder}" FontSize="48" FontWeight="Black" RenderTransform="rotate(-90deg)"/>
					</Border>

					<!-- Loaded State: Render -->
					<Grid RowDefinitions="Auto,*" IsVisible="{Binding IsFileLoaded}">
						<Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
							<TextBlock Grid.Column="0" Text="{DynamicResource ConverterInteractiveViewer}" FontWeight="Bold" Foreground="{DynamicResource EnderTextPrimary}" FontSize="16" VerticalAlignment="Center"/>
							<Border Grid.Column="1" Background="#10B98120" Padding="8,4" CornerRadius="4">
								<TextBlock Text="{DynamicResource ConverterLiveRender}" Foreground="{DynamicResource EnderSecondary}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
							</Border>
						</Grid>
						<Border Grid.Row="1" Background="{DynamicResource EnderSurfaceHover}" CornerRadius="8" BorderBrush="{DynamicResource EnderBorder}" BorderThickness="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ClipToBounds="True">
							<Grid Background="Transparent">
								<controls:MinecraftRenderControl x:Name="MainRenderControl" Triangles="{Binding MeshTriangles}" AutoRotate="False" ShowFloor="{Binding ShowFloor}" FloorColor="{Binding FloorColor}" OverrideModelColor="{Binding OverrideModelColor}" ModelColor="{Binding ModelColor}"/>
								
								<!-- Controles Superpuestos -->
								<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="16" Opacity="0.6" IsHitTestVisible="False">
									<TextBlock Text="🖱️" FontSize="16" Foreground="{DynamicResource EnderTextSecondary}" VerticalAlignment="Center"/>
									<TextBlock Text="zoom" FontSize="14" Foreground="{DynamicResource EnderTextSecondary}" VerticalAlignment="Center" FontFamily="Comic Sans MS, Cursive"/>
								</StackPanel>
								<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="16" Opacity="0.6" IsHitTestVisible="False">
									<TextBlock Text="🖱️" FontSize="16" Foreground="{DynamicResource EnderTextSecondary}" VerticalAlignment="Center"/>
									<TextBlock Text="rotate" FontSize="14" Foreground="{DynamicResource EnderTextSecondary}" VerticalAlignment="Center" FontFamily="Comic Sans MS, Cursive"/>
								</StackPanel>

                                <!-- OVERLAY DE CARGA -->
                                <Border Background="#D00B0B13" IsVisible="{Binding IsLoadingMesh}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                                        <TextBlock Text="{DynamicResource ConverterGeneratingMesh}" Foreground="{DynamicResource EnderPrimary}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                                        <ProgressBar IsIndeterminate="True" Foreground="{DynamicResource EnderPrimary}" HorizontalAlignment="Stretch" MinWidth="150"/>
                                        <TextBlock Text="{DynamicResource ConverterWaitMsg}" Foreground="{DynamicResource EnderTextSecondary}" FontSize="12" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
							</Grid>
						</Border>
					</Grid>
				</Panel>
			</Border>
		</Grid>

		<!-- OVERLAY POPUP: Guardar Proyecto -->
		<Border Grid.RowSpan="2" Background="#D0000000" IsVisible="{Binding IsSavePopupOpen}" ZIndex="100" Margin="-32">
			<Border Classes="Card" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="800">
				<Grid ColumnDefinitions="*,*">
					
					<!-- Columna Izquierda: Input y Botones -->
					<StackPanel Grid.Column="0" Spacing="24" Margin="0,0,32,0" VerticalAlignment="Center">
						<TextBlock Text="{DynamicResource ConverterSavePopupTitle}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource EnderTextPrimary}"/>
						<TextBlock Text="{DynamicResource ConverterSavePopupDesc}" Foreground="{DynamicResource EnderTextSecondary}" FontSize="14" TextWrapping="Wrap"/>
						
						<TextBox Text="{Binding NewProjectName}" Watermark="{DynamicResource ConverterSavePopupPlaceholder}" Background="{DynamicResource EnderSurfaceHover}" Foreground="{DynamicResource EnderTextPrimary}" BorderBrush="{DynamicResource EnderBorder}" Padding="16,12" CornerRadius="8" FontSize="16"/>

						<Grid ColumnDefinitions="*,*" Margin="0,16,0,0">
							<Button Grid.Column="0" Content="{DynamicResource ConverterCancelBtn}" Command="{Binding CloseSavePopupCommand}" Classes="Ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,14" Margin="0,0,8,0"/>
							<Button Grid.Column="1" Content="{DynamicResource ConverterSaveBtn}" Command="{Binding ConfirmSaveToAppCommand}" Classes="Primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="0,14" Margin="8,0,0,0"/>
						</Grid>
					</StackPanel>

					<!-- Columna Derecha: Selección de Miniaturas (Grid 2x2) -->
					<Grid Grid.Column="1" RowDefinitions="*,*" ColumnDefinitions="*,*" RowSpacing="16" ColumnSpacing="16" Height="300" Width="300">
						<!-- Img 1 (0) -->
						<Button Grid.Row="0" Grid.Column="0" Padding="0" CornerRadius="8" Command="{Binding SelectThumbnailCommand}" CommandParameter="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent">
							<Border BorderBrush="{Binding SelectedThumbnailIndex, Converter={StaticResource SelectedThumbnailConverter}, ConverterParameter=0}" BorderThickness="3" CornerRadius="8" ClipToBounds="True">
								<Image Source="{Binding Thumbnails[0]}" Stretch="UniformToFill"/>
							</Border>
						</Button>
						
						<!-- Img 2 (1) -->
						<Button Grid.Row="0" Grid.Column="1" Padding="0" CornerRadius="8" Command="{Binding SelectThumbnailCommand}" CommandParameter="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent">
							<Border BorderBrush="{Binding SelectedThumbnailIndex, Converter={StaticResource SelectedThumbnailConverter}, ConverterParameter=1}" BorderThickness="3" CornerRadius="8" ClipToBounds="True">
								<Image Source="{Binding Thumbnails[1]}" Stretch="UniformToFill"/>
							</Border>
						</Button>

						<!-- Img 3 (2) -->
						<Button Grid.Row="1" Grid.Column="0" Padding="0" CornerRadius="8" Command="{Binding SelectThumbnailCommand}" CommandParameter="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent">
							<Border BorderBrush="{Binding SelectedThumbnailIndex, Converter={StaticResource SelectedThumbnailConverter}, ConverterParameter=2}" BorderThickness="3" CornerRadius="8" ClipToBounds="True">
								<Image Source="{Binding Thumbnails[2]}" Stretch="UniformToFill"/>
							</Border>
						</Button>

						<!-- Img 4 (3) -->
						<Button Grid.Row="1" Grid.Column="1" Padding="0" CornerRadius="8" Command="{Binding SelectThumbnailCommand}" CommandParameter="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent">
							<Border BorderBrush="{Binding SelectedThumbnailIndex, Converter={StaticResource SelectedThumbnailConverter}, ConverterParameter=3}" BorderThickness="3" CornerRadius="8" ClipToBounds="True">
								<Image Source="{Binding Thumbnails[3]}" Stretch="UniformToFill"/>
							</Border>
						</Button>
					</Grid>

				</Grid>
			</Border>
		</Border>
	</Grid>
</UserControl>