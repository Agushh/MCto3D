<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:MCto3D.ViewModels"
			 x:Class="MCto3D.Views.DashboardView"
			 x:DataType="vm:DashboardViewModel">

	<Grid ColumnDefinitions="*,380" Margin="24">
		<StackPanel Grid.Column="0" Spacing="20" Margin="0,0,12,0">
			<StackPanel Spacing="4">
				<TextBlock Text="Conversor Paramétrico" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC"/>
				<TextBlock Text="Configure los parámetros de conversión de voxels." Foreground="#64748B" FontSize="13"/>
			</StackPanel>

	<Button Content="Seleccionar Archivo NBT"
			Command="{Binding LoadFileCommand}"
			CommandParameter="{Binding $parent[UserControl]}"
			Background="#3B82F6" Foreground="White" FontWeight="SemiBold"
			Padding="24,12" CornerRadius="6" HorizontalAlignment="Center"/>
        <TextBlock Text="Soporta archivos .nbt exportados de Structure Blocks vanilla." Foreground="#94A3B8" FontSize="11" HorizontalAlignment="Center"/>

			<Border Background="#111827" CornerRadius="10" Padding="20" BorderBrush="#1F2937" BorderThickness="1" IsVisible="{Binding IsFileLoaded}">
				<StackPanel Spacing="16">
					<Grid ColumnDefinitions="160,*">
						<TextBlock Grid.Column="0" Text="Escala de Bloque (bs):" VerticalAlignment="Center" Foreground="#94A3B8"/>
						<NumericUpDown Grid.Column="1" Value="{Binding Bs}" Minimum="0.01" Maximum="10" Increment="0.05"/>
					</Grid>

					<Grid ColumnDefinitions="160,*">
						<TextBlock Grid.Column="0" Text="Formato de salida:" VerticalAlignment="Center" Foreground="#94A3B8"/>
						<ComboBox Grid.Column="1" HorizontalAlignment="Stretch" SelectedItem="{Binding ExportFormat}">
							<x:String>STL</x:String>
							<x:String>3MF</x:String>
						</ComboBox>
					</Grid>

					<Grid ColumnDefinitions="160,*" IsVisible="{Binding Is3MfSelected}">
						<TextBlock Grid.Column="0" Text="Gestión de color 3MF:" VerticalAlignment="Center" Foreground="#94A3B8"/>
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
							<RadioButton Content="Monocolor" IsChecked="{Binding IsSingleColorMode}"/>
							<RadioButton Content="Multicolor (NBT)" IsChecked="{Binding IsMultiColorMode}"/>
						</StackPanel>
					</Grid>

					<Grid ColumnDefinitions="160,*" IsVisible="{Binding IsColorSelectorVisible}">
						<TextBlock Grid.Column="0" Text="Color del modelo:" VerticalAlignment="Center" Foreground="#94A3B8"/>
						<ComboBox Grid.Column="1" SelectedItem="{Binding SelectedColor}" Width="160">
							<x:String>#808080</x:String>
							<x:String>#FF0000</x:String>
							<x:String>#00FF00</x:String>
						</ComboBox>
					</Grid>

					<Button Content="Procesar y Generar Malla" Command="{Binding GenerateFileCommand}" Background="#10B981" Foreground="White" HorizontalAlignment="Right" Padding="16,8" CornerRadius="6"/>
				</StackPanel>
			</Border>
		</StackPanel>

		<Border Grid.Column="1" Background="#0F172A" CornerRadius="10" Padding="16" Margin="12,0,0,0" BorderBrush="#1F2937" BorderThickness="1">
			<Grid RowDefinitions="Auto,*">
				<TextBlock Grid.Row="0" Text="Demo de Configuración" FontWeight="Bold" Foreground="#F8FAFC" Margin="0,0,0,12"/>
				<Border Grid.Row="1" Background="#020617" CornerRadius="8">
					<TextBlock Text="[Preview voxel]" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#334155"/>
				</Border>
			</Grid>
		</Border>
	</Grid>
</UserControl>