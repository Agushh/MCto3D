<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MCto3D.ViewModels"
             x:Class="MCto3D.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             x:Name="RootControl">
    <Grid Margin="32" RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Classes="H1" FontSize="32" Text="{DynamicResource SettingsTitle}" LetterSpacing="0.5"/>
            <TextBlock Classes="Subtitle" Text="{DynamicResource SettingsLanguageDesc}" Margin="0,5,0,0"/>
        </StackPanel>
        
        <TabControl Classes="options" Grid.Row="1" TabStripPlacement="Left" Background="Transparent" IsEnabled="{Binding !IsMovingFiles}">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="FontSize" Value="16"/>
                    <Setter Property="FontWeight" Value="Medium"/>
                    <Setter Property="Foreground" Value="{DynamicResource EnderTextSecondary}"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Padding" Value="16,12"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="MinWidth" Value="160"/>
                    <Setter Property="MinHeight" Value="46"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
                
                <Style Selector="TabItem /template/ Border#PART_LayoutRoot">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>

                <!-- Normal Pointerover -->
                <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
                    <Setter Property="Background" Value="{DynamicResource EnderSurfaceHover}"/>
                </Style>
                <Style Selector="TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource EnderPrimary}"/>
                </Style>

                <!-- Selected -->
                <Style Selector="TabItem:selected /template/ Border#PART_LayoutRoot">
                    <Setter Property="Background" Value="{DynamicResource EnderSurfaceHover}"/>
                </Style>
                <Style Selector="TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource EnderPrimary}"/>
                </Style>

                <!-- Selected + Pointerover -->
                <Style Selector="TabItem:selected:pointerover /template/ Border#PART_LayoutRoot">
                    <Setter Property="Background" Value="{DynamicResource EnderSurfaceHover}"/>
                </Style>
                <Style Selector="TabItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="TextElement.Foreground" Value="{DynamicResource EnderPrimary}"/>
                </Style>

                <!-- Hide the left vertical bar -->
                <Style Selector="TabItem /template/ Border#PART_SelectedPipe">
                    <Setter Property="IsVisible" Value="False"/>
                </Style>
            </TabControl.Styles>

            <!-- TAB: GENERAL -->
            <TabItem Header="{DynamicResource SettingsGeneral}">
                <ScrollViewer Margin="32,0,0,0">
                    <StackPanel Spacing="24">
                        <Border Classes="Card" Padding="24">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Classes="H3" Text="{DynamicResource SettingsLanguage}"/>
                                    <TextBlock Classes="Subtitle" Text="{DynamicResource SettingsLanguageDesc}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedLanguageIndex, FallbackValue=0}" Width="150" VerticalAlignment="Center">
                                    <ComboBoxItem Content="English" />
                                    <ComboBoxItem Content="Español" />
                                </ComboBox>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB: FILES -->
            <TabItem Header="{DynamicResource SettingsLocalFiles}">
                <ScrollViewer Margin="32,0,0,0">
                    <StackPanel Spacing="24">
                        
                        <!-- MC Version -->
                        <Border Classes="Card" Padding="24">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Classes="H3" Text="{DynamicResource SettingsMCVersion}"/>
                                    <TextBlock Classes="Subtitle" Text="{DynamicResource SettingsMCVersionDesc}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{DynamicResource EnderSurfaceHover}" BorderBrush="{DynamicResource EnderBorder}" BorderThickness="1" CornerRadius="8" Padding="16,8" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding LoadedMinecraftVersion}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource EnderPrimary}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Local Path -->
                        <Border Classes="Card" Padding="24">
                            <StackPanel Spacing="16">
                                <Grid ColumnDefinitions="*">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Classes="H3" Text="{DynamicResource SettingsLocalPath}"/>
                                        <TextBlock Classes="Subtitle" Text="{DynamicResource SettingsLocalPathDesc}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                                
                                <TextBox Classes="Modern" Text="{Binding LocalFilesPath}" IsReadOnly="True" Foreground="{DynamicResource EnderTextSecondary}"/>
                                
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <Button Content="{DynamicResource SettingsOpenFolder}" Command="{Binding OpenLocalFilesFolderCommand}" Classes="Ghost" Padding="16,10"/>
                                        <Button Content="{DynamicResource SettingsRestoreFolder}" Command="{Binding RestoreDefaultLocalFilesPathCommand}" Classes="Ghost" Foreground="{DynamicResource EnderPrimary}" Padding="16,10" IsVisible="{Binding IsNotDefaultPath}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="{DynamicResource SettingsChangePathBtn}" Command="{Binding ChangeLocalFilesPathCommand}" Classes="Outline" Padding="16,10" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Reload Actions -->
                        <Border Classes="Card" Padding="24">
                            <StackPanel Spacing="16">
                                <TextBlock Classes="H3" Text="{DynamicResource SettingsReloadActions}"/>
                                
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Classes="Subtitle" FontWeight="SemiBold" Foreground="{DynamicResource EnderTextPrimary}" Text="{DynamicResource SettingsReloadBaseFiles}"/>
                                        <TextBlock Classes="Subtitle" FontSize="12" Text="{DynamicResource SettingsReloadBaseFilesDesc}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="{DynamicResource SettingsReloadBtn}" Command="{Binding ReloadBaseFilesCommand}" Classes="Outline" Padding="16,8" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB: CONVERTER -->
            <TabItem Header="Converter">
                <ScrollViewer Margin="32,0,0,0">
                    <StackPanel Spacing="24">
                        <Border Classes="Card" Padding="24">
                            <Grid ColumnDefinitions="160,*">
                                <StackPanel Grid.Column="0" VerticalAlignment="Top">
                                    <TextBlock Classes="H3" Text="{DynamicResource SettingsConverter3MfOptions}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <RadioButton Content="{DynamicResource SettingsConverter3MfAssembly}" IsChecked="{Binding Use3MfAssemblyMode}" Foreground="{DynamicResource EnderTextPrimary}"/>
                                    <RadioButton Content="{DynamicResource SettingsConverter3MfSeparate}" IsChecked="{Binding !Use3MfAssemblyMode}" Foreground="{DynamicResource EnderTextPrimary}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Classes="Card" Padding="24">
                            <StackPanel Spacing="16">
                                <TextBlock Classes="H3" Text="{DynamicResource SettingsConverterPaletteManagement}"/>
                                
                                <Grid ColumnDefinitions="*,*">
                                    <Button Grid.Column="0" Content="{DynamicResource SettingsConverterManagePalettes}" Command="{Binding OpenPaletteManagerCommand}" Classes="Primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="{DynamicResource SettingsConverterDeleteAllPalettes}" Command="{Binding DeleteAllPalettesCommand}" Background="#EF4444" Foreground="White" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

	<!-- TAB: RENDERER -->
	<TabItem Header="{DynamicResource SettingsRenderer}">
		<ScrollViewer Margin="32,0,0,0">
			<Border Classes="Card" Padding="24">
				<StackPanel Spacing="16">
					<TextBlock Classes="H3" Text="{DynamicResource SettingsRendererVisuals}"/>

					<Grid ColumnDefinitions="160,*">
						<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource SettingsRendererFloor}"/>
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
							<CheckBox IsChecked="{Binding ShowFloor}" Foreground="{DynamicResource EnderTextPrimary}"/>
							<ColorPicker Color="{Binding FloorColor}" IsVisible="{Binding ShowFloor}" Height="32"/>
						</StackPanel>
					</Grid>

					<Grid ColumnDefinitions="160,*">
						<TextBlock Grid.Column="0" Classes="SettingsLabel" Text="{DynamicResource SettingsRendererMeshColor}"/>
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
							<ColorPicker Color="{Binding ModelColor}" Height="32"/>
						</StackPanel>
					</Grid>
				</StackPanel>
			</Border>
		</ScrollViewer>
	</TabItem>

	<!-- TAB: ABOUT -->
	<TabItem Header="{DynamicResource SettingsAbout}">
		<ScrollViewer Margin="32,0,0,0">
			<Border Classes="Card" Padding="24">
				<TextBlock Text="MCto3D Version 1.0.0" Foreground="{DynamicResource EnderTextSecondary}"/>
			</Border>
		</ScrollViewer>
            </TabItem>

        </TabControl>

	<!-- PANTALLA DE CARGA (MOVIMIENTO DE ARCHIVOS) -->
	<Border Grid.Row="0" Grid.RowSpan="2" Background="#D9000000" IsVisible="{Binding IsMovingFiles}" ZIndex="100">
		<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
			<TextBlock Classes="H1" FontSize="32" Text="{DynamicResource SettingsMovingFiles}" HorizontalAlignment="Center"/>
			<TextBlock Classes="Subtitle" FontSize="16" Text="{Binding MovingProgressMessage}" HorizontalAlignment="Center"/>
			<ProgressBar IsIndeterminate="True" Foreground="{DynamicResource EnderPrimary}" Background="{DynamicResource EnderSurfaceHover}" Height="4" Width="300" CornerRadius="2"/>
		</StackPanel>
        </Border>

        <!-- PANTALLA GESTION DE PALETAS -->
<Border Grid.Row="0" Grid.RowSpan="2" Background="#D9000000" IsVisible="{Binding IsPaletteManagerOpen}" ZIndex="100">
	<Border Background="{DynamicResource EnderSurface}" CornerRadius="12" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="400" MaxWidth="600" MaxHeight="500">
		<Grid RowDefinitions="Auto,*,Auto">
			<TextBlock Grid.Row="0" Classes="H2" Text="{DynamicResource SettingsConverterManagePalettes}" Margin="0,0,0,16"/>
			<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
				<ItemsControl ItemsSource="{Binding SavedPalettes}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
								<TextBox Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" Margin="0,0,8,0"/>
								<Button Grid.Column="1" Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeletePaletteCommand}" CommandParameter="{Binding}" Classes="Danger" Padding="8">
									<TextBlock Text="🗑️" FontSize="14"/>
								</Button>
							</Grid>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
			<StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
				<Button Content="{DynamicResource GlobalClose}" Command="{Binding ClosePaletteManagerCommand}" Classes="Ghost"/>
				<Button Content="{DynamicResource GlobalSaveChanges}" Command="{Binding SavePaletteManagerCommand}" Classes="Primary"/>
			</StackPanel>
		</Grid>
	</Border>
        </Border>

    </Grid>
</UserControl>
