<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MCto3D.ViewModels"
             x:Class="MCto3D.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    
    <Grid Margin="30" RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="Ajustes" FontSize="32" FontWeight="Black" Foreground="#F8FAFC" LetterSpacing="0.5"/>
            <TextBlock Text="Configuración general del programa." FontSize="14" Foreground="#94A3B8" Margin="0,5,0,0"/>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="25">
                <!-- APARTADO ARCHIVOS -->
                <StackPanel Spacing="15">
                    <TextBlock Text="ARCHIVOS" Foreground="#64748B" FontWeight="Bold" FontSize="14" LetterSpacing="1"/>
                    
                    <Border Background="#1A1528" BorderBrush="#2D2445" BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="15">
                            
                            <!-- Botón 1 -->
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Recargar archivos del juego base" FontSize="16" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                    <TextBlock Text="Abre el seleccionador de carpetas para extraer los assets de Minecraft nuevamente." FontSize="14" Foreground="#94A3B8" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" 
                                        Content="Recargar" 
                                        Command="{Binding ReloadBaseFilesCommand}"
                                        Background="#334155" Foreground="White" 
                                        FontWeight="SemiBold" Padding="20,10" CornerRadius="8"
                                        Cursor="Hand" VerticalAlignment="Center" Margin="20,0,0,0"/>
                            </Grid>

                            <Border Height="1" Background="#2D2445" Margin="0,5"/>

                            <!-- Botón 2 -->
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Recargar modelos" FontSize="16" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                    <TextBlock Text="Vuelve a procesar los modelos estáticos en memoria utilizando la ruta actualmente configurada." FontSize="14" Foreground="#94A3B8" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" 
                                        Content="Re-procesar" 
                                        Command="{Binding ReloadModelsCommand}"
                                        Background="#9333EA" Foreground="White" 
                                        FontWeight="SemiBold" Padding="20,10" CornerRadius="8"
                                        Cursor="Hand" VerticalAlignment="Center" Margin="20,0,0,0"/>
                            </Grid>
                            
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- OTROS APARTADOS PODRÍAN IR AQUÍ -->
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
