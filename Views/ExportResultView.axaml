<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:MCto3D.ViewModels"
			 x:Class="MCto3D.Views.ExportResultView"
			 x:DataType="vm:ExportResultViewModel">

	<Grid RowDefinitions="Auto,*,Auto" Margin="24">
		<StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,16">
			<TextBlock Text="Malla 3D Generada con Éxito" FontSize="22" FontWeight="Bold" Foreground="#10B981"/>
			<TextBlock Text="Analice la topología antes de guardar el archivo." Foreground="#64748B" FontSize="13"/>
		</StackPanel>

		<Border Grid.Row="1" Background="#020617" CornerRadius="10" BorderBrush="#1F2937" BorderThickness="1">
			<TextBlock Text="[Visor 3D del Archivo Procesado y Centrado]" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#334155" FontSize="14" FontWeight="SemiBold"/>
		</Border>

		<Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,16,0,0">
			<Button Grid.Column="0" Content="Volver a la Configuración" Command="{Binding BackToDashboardCommand}" Background="Transparent" BorderBrush="#334155" BorderThickness="1" Foreground="#94A3B8" Padding="14,10" CornerRadius="6"/>

			<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
				<Button Content="Abrir en mi Slicer" Command="{Binding OpenInSlicerCommand}" Background="#4B5563" Foreground="White" Padding="16,10" CornerRadius="6"/>
				<Button Content="Exportar Archivo Final"
						Command="{Binding ExportFileCommand}"
						CommandParameter="{Binding $parent[UserControl]}"
						Background="#3B82F6" Foreground="White" FontWeight="Bold"
						Padding="22,10" CornerRadius="6"/>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>