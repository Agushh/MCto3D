<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MCto3D.ViewModels"
             x:Class="MCto3D.Views.LoadingView"
             x:DataType="vm:LoadingViewModel"
             Background="{DynamicResource EnderSurface}"> <!-- Fondo completamente opaco -->

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="25" IsVisible="{Binding !HasError}">
            <TextBlock Classes="H1" FontSize="36"
                       Text="Generando modelos..." 
                       HorizontalAlignment="Center" 
                       LetterSpacing="1"/>
            
            <ProgressBar IsIndeterminate="True" 
                         Width="400" 
                         Height="8" 
                         Foreground="{DynamicResource EnderPrimary}" 
                         Background="{DynamicResource EnderSurfaceHover}" 
                         CornerRadius="4"/>
            
            <TextBlock Classes="H3" Foreground="{DynamicResource EnderPrimaryHover}" 
                       Text="{Binding StatusMessage}" 
                       HorizontalAlignment="Center" 
                       FontStyle="Italic"/>
        </StackPanel>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20" IsVisible="{Binding HasError}">
            <TextBlock Classes="H1" FontSize="32" Foreground="#EF4444" 
                       Text="Ha ocurrido un error" 
                       HorizontalAlignment="Center"/>
            
            <Border Background="#2A1015" BorderBrush="#7F1D1D" BorderThickness="1" CornerRadius="8" Padding="20" MaxWidth="600">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" TextWrapping="Wrap"/>
            </Border>
            
            <Button Classes="Danger" Content="Cerrar y continuar" 
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).HideLoadingScreenCommand}"
                    Padding="20,10" 
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
