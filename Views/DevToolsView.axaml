<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MCto3D.ViewModels"
             x:Class="MCto3D.Views.DevToolsView"
             x:DataType="vm:DevToolsViewModel">
    
    <Grid Margin="30" RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="Development Tools" FontSize="32" FontWeight="Black" Foreground="#F8FAFC" LetterSpacing="0.5"/>
            <TextBlock Text="Herramientas internas para desarrollo y depuración." FontSize="14" Foreground="#94A3B8" Margin="0,5,0,0"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Spacing="15">
            <Border Background="#1A1528" BorderBrush="#2D2445" BorderThickness="1" CornerRadius="12" Padding="20">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Models Extractor Service" FontSize="18" FontWeight="Bold" Foreground="#F8FAFC"/>
                        <TextBlock Text="Ejecuta la extracción y generación de modelos crudos basados en los assets de Minecraft." FontSize="14" Foreground="#94A3B8" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" 
                            Content="Generate Crude Models" 
                            Background="#9333EA" Foreground="White" 
                            FontWeight="SemiBold" Padding="20,12" CornerRadius="8"
                            Cursor="Hand" VerticalAlignment="Center" Margin="20,0,0,0"/>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
