<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MCto3D.ViewModels"
             x:Class="MCto3D.Views.WalkthroughView"
             x:DataType="vm:WalkthroughViewModel">
    <Grid Margin="32">
        <TextBlock Text="Walkthrough" FontSize="32" FontWeight="Black" Foreground="{DynamicResource EnderTextPrimary}"/>
        <!-- Contenido de walkthrough a definir más adelante -->
    </Grid>
</UserControl>
