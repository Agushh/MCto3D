<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:MCto3D.ViewModels"
			 xmlns:conv="using:MCto3D.Converters"
			 x:Class="MCto3D.Views.MyFilesView"
			 x:DataType="vm:MyFilesViewModel">

	<UserControl.Resources>
		<conv:PathToBitmapConverter x:Key="PathToBitmapConverter"/>
	</UserControl.Resources>

	<UserControl.Styles>
		<!-- Estilo premium para las tarjetas de proyectos (botones) -->
		<Style Selector="Button.ProjectCard">
			<Setter Property="Background" Value="{DynamicResource EnderSurface}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource EnderBorder}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Transitions">			
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.2"/>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
				</Transitions>
			</Setter>
		</Style>
		
		<Style Selector="Button.ProjectCard:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource EnderSurfaceHover}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource EnderPrimary}"/>
		</Style>
		
		<!-- Pequeño efecto de escala al hacer hover en las tarjetas -->
		<Style Selector="Button.ProjectCard:pointerover">
			<Setter Property="RenderTransform" Value="scale(1.02)"/>
		</Style>
	</UserControl.Styles>

	<Grid Margin="32">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- HEADER & CONTROLS -->
		<Grid Grid.Row="0" Margin="0,0,0,24">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<!-- Title and Search -->
			<StackPanel Grid.Column="0" Spacing="16" VerticalAlignment="Center">
				<TextBlock Classes="H1" Text="{DynamicResource MyFilesTitle}"/>
				<Grid ColumnDefinitions="300,Auto,Auto" Margin="0,8,0,0">
					<TextBox Grid.Column="0" Classes="Modern" Text="{Binding SearchText}" PlaceholderText="{DynamicResource MyFilesSearch}"/>
					
					<!-- Sort Selector -->
					<ComboBox Grid.Column="1" Classes="Modern" SelectedIndex="{Binding SelectedSortIndex}" Margin="16,0,0,0" VerticalAlignment="Center">
						<x:String>Más Recientes</x:String>
						<x:String>Nombre (A-Z)</x:String>
					</ComboBox>

					<!-- View Toggles -->
					<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
						<Button Command="{Binding SetGridViewCommand}" Classes="Ghost" Padding="12,8" ToolTip.Tip="{DynamicResource MyFilesViewGrid}">
							<TextBlock Text="⊞" FontSize="16"/>
						</Button>
						<Button Command="{Binding SetListViewCommand}" Classes="Ghost" Padding="12,8" ToolTip.Tip="{DynamicResource MyFilesViewList}">
							<TextBlock Text="☰" FontSize="16"/>
						</Button>
					</StackPanel>
				</Grid>
			</StackPanel>

			<!-- BACK BUTTONS -->
			<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
				<Button Command="{Binding GoBackCommand}" Classes="Outline" Padding="16,12">
					<StackPanel Orientation="Horizontal" Spacing="8">
						<TextBlock Text="←" VerticalAlignment="Center" FontSize="16"/>
						<TextBlock Text="{DynamicResource MyFilesBack}" VerticalAlignment="Center" FontWeight="Bold"/>
					</StackPanel>
				</Button>
			</StackPanel>
		</Grid>

		<!-- CONTENT: EMPTY STATE OR ITEMS -->
		<Grid Grid.Row="1">
			<!-- Empty State -->
			<StackPanel IsVisible="{Binding !Projects.Count}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
				<TextBlock Text="📭" FontSize="64" HorizontalAlignment="Center"/>
				<TextBlock Classes="H3" Foreground="{DynamicResource EnderTextSecondary}" Text="{DynamicResource MyFilesEmpty}" HorizontalAlignment="Center"/>
			</StackPanel>

			<!-- GRID VIEW -->
			<ScrollViewer IsVisible="{Binding IsGridView}">
				<ItemsControl ItemsSource="{Binding Projects}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel Orientation="Horizontal" Margin="0"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Command="{Binding $parent[UserControl].((vm:MyFilesViewModel)DataContext).OpenProjectCommand}" CommandParameter="{Binding}" 
									Classes="ProjectCard" Width="220" Margin="8">
								<StackPanel>
									<!-- Image -->
									<Border Background="{DynamicResource EnderSurfaceHover}" Height="140" CornerRadius="11,11,0,0" ClipToBounds="True">
										<Panel>
											<TextBlock Text="📸" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
											<Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToBitmapConverter}}" Stretch="UniformToFill"/>
										</Panel>
									</Border>
									<!-- Info -->
									<Border Padding="16">
										<StackPanel Spacing="4">
											<TextBlock Classes="H3" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
											<TextBlock Classes="Subtitle" FontSize="11" Text="{Binding FormattedDate}"/>
										</StackPanel>
									</Border>
								</StackPanel>
							</Button>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>

			<!-- LIST VIEW -->
			<ScrollViewer IsVisible="{Binding IsListView}">
				<ItemsControl ItemsSource="{Binding Projects}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Command="{Binding $parent[UserControl].((vm:MyFilesViewModel)DataContext).OpenProjectCommand}" CommandParameter="{Binding}" 
									Classes="ProjectCard" HorizontalAlignment="Stretch" Margin="0,0,0,12">
								<Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="12" VerticalAlignment="Center">
									<!-- Image -->
									<Border Grid.Column="0" Background="{DynamicResource EnderSurfaceHover}" Width="60" Height="60" CornerRadius="6" Margin="0,0,16,0" ClipToBounds="True">
										<Panel>
											<TextBlock Text="📸" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
											<Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToBitmapConverter}}" Stretch="UniformToFill"/>
										</Panel>
									</Border>
									
									<!-- Name & Path -->
									<StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
										<TextBlock Classes="H3" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
										<TextBlock Classes="Subtitle" FontSize="12" Text="{Binding FormattedDate}"/>
									</StackPanel>
									
									<!-- Format & Geometry -->
									<StackPanel Grid.Column="2" VerticalAlignment="Center" Width="150" Margin="0,0,16,0">
										<TextBlock Classes="H3" FontWeight="SemiBold" Text="{Binding ExportFormat}"/>
										<TextBlock Classes="Subtitle" FontSize="12" Text="{Binding GeometryMode}"/>
									</StackPanel>

									<!-- Size -->
									<TextBlock Grid.Column="3" Classes="Subtitle" Text="{Binding FileSizeStr}" Width="100" VerticalAlignment="Center"/>

									<!-- Action -->
									<Border Grid.Column="4" Background="{DynamicResource EnderSurfaceHover}" Padding="12,8" CornerRadius="6">
										<TextBlock Text="..." Foreground="{DynamicResource EnderPrimary}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>
								</Grid>
							</Button>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</ScrollViewer>
		</Grid>

		<!-- POP-UP DETAILS OVERLAY -->
		<Border Grid.RowSpan="2" Background="#80000000" IsVisible="{Binding IsPopupOpen}" ZIndex="100" Margin="-32">
			<Border Classes="Card" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center" Width="600" MinHeight="400">
				
				<Grid RowDefinitions="Auto,*,Auto">
					<!-- Header: Edit / Close -->
					<Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,24">
						<TextBlock Grid.Column="0" Classes="H2" Text="{DynamicResource MyFilesProjectDetails}" VerticalAlignment="Center"/>
						<Button Grid.Column="1" Content="✕" Command="{Binding ClosePopupCommand}" Classes="Ghost" Padding="8"/>
					</Grid>

					<!-- Content -->
					<Grid Grid.Row="1" ColumnDefinitions="200,*">
						<!-- Big Image -->
						<Border Grid.Column="0" Background="{DynamicResource EnderSurfaceHover}" CornerRadius="12" Margin="0,0,24,0" Height="200" VerticalAlignment="Top" ClipToBounds="True">
							<Panel>
								<TextBlock Text="📸 Render" FontSize="24" Foreground="{DynamicResource EnderTextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
								<Image Source="{Binding SelectedProject.ThumbnailPath, FallbackValue={x:Null}, Converter={StaticResource PathToBitmapConverter}}" Stretch="UniformToFill"/>
							</Panel>
						</Border>

						<!-- Info Vertical -->
						<StackPanel Grid.Column="1" Spacing="16">
							<!-- Name Editing Logic -->
							<StackPanel IsVisible="{Binding !IsEditingName}">
								<Grid ColumnDefinitions="*,Auto">
									<TextBlock Grid.Column="0" Classes="H2" FontSize="24" FontWeight="Black" Text="{Binding SelectedProject.Name, FallbackValue=''}" TextWrapping="Wrap"/>
									<Button Grid.Column="1" IsVisible="{Binding !SelectedProject.IsReadOnly}" Content="✎" Command="{Binding StartEditNameCommand}" Classes="Ghost" Foreground="{DynamicResource EnderPrimary}" FontSize="18" Padding="8,0"/>
								</Grid>
							</StackPanel>
							<StackPanel IsVisible="{Binding IsEditingName}" Spacing="8">
								<TextBox Classes="Modern" BorderBrush="{DynamicResource EnderPrimary}" Text="{Binding EditingNameText}" FontSize="18"/>
								<StackPanel Orientation="Horizontal" Spacing="8">
									<Button Content="{DynamicResource MyFilesSave}" Command="{Binding SaveEditNameCommand}" Classes="Primary" Padding="12,6"/>
									<Button Content="{DynamicResource MyFilesCancel}" Command="{Binding CancelEditNameCommand}" Classes="Ghost" Padding="12,6"/>
								</StackPanel>
							</StackPanel>

							<Border Height="1" Background="{DynamicResource EnderBorder}"/>

							<Grid ColumnDefinitions="100,*">
								<TextBlock Grid.Column="0" Classes="Subtitle" Text="{DynamicResource MyFilesDate}"/>
								<TextBlock Grid.Column="1" Text="{Binding SelectedProject.FormattedDate, FallbackValue=''}"/>
							</Grid>
							<Grid ColumnDefinitions="100,*">
								<TextBlock Grid.Column="0" Classes="Subtitle" Text="{DynamicResource MyFilesGeometry}"/>
								<TextBlock Grid.Column="1" Text="{Binding SelectedProject.GeometryMode, FallbackValue=''}"/>
							</Grid>
							<Grid ColumnDefinitions="100,*">
								<TextBlock Grid.Column="0" Classes="Subtitle" Text="{DynamicResource MyFilesFormat}"/>
								<TextBlock Grid.Column="1" Text="{Binding SelectedProject.ExportFormat, FallbackValue=''}"/>
							</Grid>
							<Grid ColumnDefinitions="100,*">
								<TextBlock Grid.Column="0" Classes="Subtitle" Text="{DynamicResource MyFilesScale}"/>
								<TextBlock Grid.Column="1" Text="{Binding SelectedProject.BlockScale, FallbackValue=''}"/>
							</Grid>
						</StackPanel>
					</Grid>

					<!-- Bottom Actions -->
					<Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,32,0,0">
						<!-- Delete -->
						<Button Grid.Column="0" Content="{DynamicResource MyFilesDelete}" Command="{Binding DeleteProjectCommand}" Background="#450a0a" Foreground="#f87171" FontWeight="Bold" Padding="16,12" CornerRadius="8" Cursor="Hand"/>
						
						<!-- Exporters -->
						<SplitButton Grid.Column="2" Content="{Binding SelectedSlicer.ButtonText}"
									 Command="{Binding OpenInSlicerCommand}"
									 Background="{Binding SelectedSlicer.ColorHex}"
									 Foreground="White"
									 Padding="16,12"
									 CornerRadius="8"
									 Cursor="Hand"
									 FontWeight="Bold"
									 Margin="0,0,12,0">
							<SplitButton.Flyout>
								<MenuFlyout Placement="BottomEdgeAlignedRight">
									<MenuItem Header="OrcaSlicer" Command="{Binding ChangeSlicerCommand}" CommandParameter="{Binding SlicerOptions[0]}">
										<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#027D52"/></MenuItem.Icon>
									</MenuItem>
									<MenuItem Header="BambuStudio" Command="{Binding ChangeSlicerCommand}" CommandParameter="{Binding SlicerOptions[1]}">
										<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#00AE42"/></MenuItem.Icon>
									</MenuItem>
									<MenuItem Header="PrusaSlicer" Command="{Binding ChangeSlicerCommand}" CommandParameter="{Binding SlicerOptions[2]}">
										<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#EA6B24"/></MenuItem.Icon>
									</MenuItem>
									<MenuItem Header="Cura" Command="{Binding ChangeSlicerCommand}" CommandParameter="{Binding SlicerOptions[3]}">
										<MenuItem.Icon><Ellipse Width="12" Height="12" Fill="#0055FF"/></MenuItem.Icon>
									</MenuItem>
								</MenuFlyout>
							</SplitButton.Flyout>
						</SplitButton>
						
						<Button Grid.Column="3" Content="{DynamicResource MyFilesExportLocal}" Command="{Binding ExportLocalCommand}" CommandParameter="{Binding $parent[UserControl]}" Classes="Primary" Padding="16,12"/>
					</Grid>
				</Grid>
			</Border>
		</Border>
	</Grid>
</UserControl>
