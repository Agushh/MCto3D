<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MCto3D.ViewModels"
             x:Class="MCto3D.Views.WelcomeView"
             x:DataType="vm:WelcomeViewModel"
             Background="{DynamicResource EnderBackgroundBase}">
    
    <Grid>
        <!-- CONTENIDO PRINCIPAL -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="30" MaxWidth="700">
            
            <TextBlock Classes="H1"
                       Text="{DynamicResource WelcomeTitle}" 
                       FontSize="42" 
                       HorizontalAlignment="Center" 
                       LetterSpacing="1"/>
            
            <Border Classes="Card" Padding="25">
                <TextBlock Text="{DynamicResource WelcomeDesc}"
                           Foreground="{DynamicResource EnderTextSecondary}"
                           FontSize="16"
                           TextWrapping="Wrap"
                           LineHeight="24"
                           TextAlignment="Center"/>
            </Border>

            <!-- BOTONES Y ACCIONES (Se ocultan cuando está procesando) -->
            <StackPanel Spacing="15" IsVisible="{Binding !IsProcessing}" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Classes="Primary"
                        Content="{DynamicResource WelcomeContinueBtn}" 
                        Command="{Binding ContinueWithDefaultFolderCommand}"
                        FontSize="18"
                        Padding="40,15" 
                        HorizontalAlignment="Center"
                        ToolTip.Tip="{DynamicResource WelcomeContinueTooltip}"/>

                <Button Classes="Hyperlink"
                        Content="{DynamicResource WelcomeCustomFolderBtn}"
                        Command="{Binding SelectCustomFolderCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,0"/>
            </StackPanel>

            <!-- INDICADOR DE CARGA (Visible cuando IsProcessing = true) -->
            <StackPanel Spacing="15" IsVisible="{Binding IsProcessing}" HorizontalAlignment="Center" Margin="0,20,0,0">
                <!-- Como Avalonia puro no tiene ProgressRing por defecto, usamos un ProgressBar indeterminado -->
                <ProgressBar IsIndeterminate="True" 
                             Width="300" 
                             Height="6" 
                             Foreground="{DynamicResource EnderPrimary}" 
                             Background="{DynamicResource EnderSurfaceHover}" 
                             CornerRadius="3"/>
                <TextBlock Classes="Subtitle"
                           Text="{Binding LoadingMessage}" 
                           HorizontalAlignment="Center" 
                           FontStyle="Italic"/>
            </StackPanel>
            
        </StackPanel>
    </Grid>
</UserControl>
