<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:MCto3D.ViewModels"
		x:Class="MCto3D.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Title="NBT a STL Tester" Width="400" Height="250">

	<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">

		<TextBlock Text="{Binding StatusText}"
				   FontSize="18"
				   FontWeight="Bold"
				   HorizontalAlignment="Center"/>

		<Button Content="Cargar archivo nbt"
				Command="{Binding LoadFileCommand}"
				HorizontalAlignment="Center"
				Width="150" HorizontalContentAlignment="Center"/>

		<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center"
					IsVisible="{Binding IsFileLoaded}">

			<StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
				<TextBlock Text="Tamaño del bloque:" VerticalAlignment="Center"/>
				<NumericUpDown Value="{Binding Bs, Mode=TwoWay}" Minimum="0.01" Maximum="10" Increment="0.05" Width="120"/>
			</StackPanel>

			<Button Content="Exportar a STL"
					Command="{Binding ExportToStlCommand}"
					Background="MediumSeaGreen" Foreground="White" FontWeight="Bold"/>

			<Button Content="❌"
					Command="{Binding CancelCommand}"
					Background="IndianRed" Foreground="White" ToolTip.Tip="Cancelar / Cargar otro"/>

		</StackPanel>
	</StackPanel>
</Window>